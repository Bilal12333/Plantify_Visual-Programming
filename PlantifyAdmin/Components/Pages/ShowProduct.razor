@page "/showproduct"
@layout UserLayout
@inject IPlantService productService
@inject ICartService CartService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<style>
    :root {
        --primary: #4caf50;
        --primary-dark: #2e7d32;
        --secondary: #ff6b35;
        --accent: #667eea;
        --light: #f8f9fa;
        --dark: #343a40;
        --success: #28a745;
        --warning: #ffc107;
        --danger: #dc3545;
        --gray: #6c757d;
        --light-gray: #e9ecef;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f9fbf8;
        color: #2d5016;
    }

    /* Improved Hero Section */
    .hero-section {
        background: linear-gradient(135deg, rgba(168, 224, 99, 0.9) 0%, rgba(86, 171, 47, 0.9) 100%), url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23ffffff" fill-opacity="0.1"/><path d="M0 50 L100 50 M50 0 L50 100" stroke="%23ffffff" stroke-width="1" stroke-opacity="0.2"/></svg>');
        color: white;
        padding: 3rem 0;
        margin-bottom: 2rem;
        border-radius: 0 0 30px 30px;
        position: relative;
        overflow: hidden;
    }

    /* Fixed keyframes with @@ escape */
    @@keyframes floatingLeaves {
        0% {
            transform: translateY(0) translateX(0);
        }

        100% {
            transform: translateY(-100px) translateX(100px);
        }
    }

    /* Improved Navbar */
    .navbar-custom {
        background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        padding: 0.8rem 0;
    }

    .navbar-brand {
        font-weight: 800;
        font-size: 1.8rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    /* Improved Product Cards */
    .product-card {
        transition: all 0.3s ease;
        border-radius: 16px;
        overflow: hidden;
        background: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        border: none;
        height: 100%;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(46, 125, 50, 0.15);
        }

    .product-image-container {
        overflow: hidden;
        position: relative;
        height: 220px;
    }

    .product-image {
        height: 100%;
        width: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-image {
        transform: scale(1.08);
    }

    .product-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: var(--success);
        color: white;
        border-radius: 20px;
        padding: 4px 10px;
        font-size: 0.75rem;
        font-weight: 600;
        box-shadow: 0 3px 8px rgba(0,0,0,0.15);
    }

    .card-body {
        padding: 1.5rem;
    }

    .product-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
        color: var(--dark);
        line-height: 1.3;
        height: 2.6em;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .product-category {
        color: var(--gray);
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
    }

    .product-price {
        font-weight: 800;
        font-size: 1.25rem;
        color: var(--primary-dark);
        margin-bottom: 1rem;
    }

    /* Improved Buttons */
    .btn-add-cart {
        background: linear-gradient(45deg, var(--primary), var(--primary-dark));
        border: none;
        color: white;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-add-cart:hover {
            background: linear-gradient(45deg, var(--primary-dark), var(--primary));
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(76, 175, 80, 0.4);
        }

    .btn-cart {
        background: linear-gradient(45deg, var(--secondary), #f7931e);
        border: none;
        color: white;
        border-radius: 10px;
        padding: 8px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-cart:hover {
            background: linear-gradient(45deg, #f7931e, var(--secondary));
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(247, 147, 30, 0.4);
        }

    .btn-checkout {
        background: linear-gradient(45deg, var(--accent), #764ba2);
        border: none;
        color: white;
        border-radius: 10px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-checkout:hover {
            background: linear-gradient(45deg, #764ba2, var(--accent));
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

    /* Improved Category Buttons */
    .category-btn {
        border-radius: 10px;
        border: 2px solid rgba(255,255,255,0.3);
        background: rgba(255,255,255,0.1);
        transition: all 0.3s ease;
        color: white;
        padding: 8px 16px;
        margin: 0 5px 5px 0;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .category-btn:hover {
            background: rgba(255,255,255,0.2);
            border-color: rgba(255,255,255,0.5);
            transform: translateY(-2px);
        }

    /* Improved Dropdown */
    .dropdown-menu {
        border-radius: 12px;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        padding: 0.5rem;
    }

    .dropdown-item {
        border-radius: 8px;
        padding: 0.5rem 1rem;
        transition: all 0.2s ease;
    }

        .dropdown-item:hover {
            background-color: rgba(76, 175, 80, 0.1);
        }

    /* Improved Offcanvas */
    .offcanvas-custom {
        border-radius: 20px 0 0 20px;
        box-shadow: -5px 0 30px rgba(0,0,0,0.15);
    }

    .offcanvas-header-custom {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border-radius: 20px 0 0 0;
        padding: 1.2rem 1.5rem;
    }

    /* Improved Cart Items */
    .cart-item {
        border-radius: 12px;
        background: white;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
        margin-bottom: 1rem;
        overflow: visible;
        transition: all 0.3s ease;
    }

        .cart-item:hover {
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transform: translateY(-2px);
        }

    /* Improved Quantity Controls */
    .quantity-controls {
        background: var(--light);
        border-radius: 10px;
        padding: 3px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: 1px solid var(--light-gray);
    }

    .quantity-btn {
        width: 25px;
        height: 25px;
        border-radius: 8px;
        border: none;
        color: white;
        font-weight: bold;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .quantity-btn-decrease {
        background: var(--danger);
    }

        .quantity-btn-decrease:hover {
            background: #bd2130;
            transform: scale(1.05);
        }

    .quantity-btn-increase {
        background: var(--success);
    }

        .quantity-btn-increase:hover {
            background: #218838;
            transform: scale(1.05);
        }

    .quantity-display {
        background: white;
        border-radius: 8px;
        padding: 2px 8px;
        font-weight: 600;
        color: var(--dark);
        min-width: 30px;
        text-align: center;
        border: 1px solid var(--light-gray);
    }

    /* Improved Checkout Form */
    .checkout-form {
        background: white;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .form-control-custom {
        border-radius: 10px;
        border: 2px solid var(--light-gray);
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(76, 175, 80, 0.25);
        }

    .order-summary {
        background: linear-gradient(135deg, var(--accent), #764ba2);
        color: white;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.2);
    }

    /* Improved Footer */
    .footer {
        background: linear-gradient(to right, #2d5016 0%, #4caf50 100%);
        color: white;
        padding: 3rem 0 2rem;
        margin-top: 3rem;
    }

        .footer a {
            color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
            text-decoration: none;
        }

            .footer a:hover {
                color: white;
                text-decoration: none;
            }

    .social-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        color: white;
        transition: 0.3s;
        margin-right: 10px;
    }

        .social-icon:hover {
            background: white;
            color: var(--primary);
            border-color: white;
            transform: translateY(-3px);
        }

    /* Animations */
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    .fade-in {
        animation: fadeIn 0.6s ease-out;
    }

    .pulse {
        animation: pulse 1.5s infinite;
    }

    /* Loading Spinner */
    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid rgba(76, 175, 80, 0.3);
        border-radius: 50%;
        border-top: 4px solid var(--primary);
        animation: spin 1s linear infinite;
        margin: 0 auto;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--gray);
    }

    .empty-state-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
        color: var(--primary);
    }

    /* Responsive Improvements */
    @@media (max-width: 768px) {
        .hero-section {
            padding: 2rem 0;
            border-radius: 0 0 20px 20px;
        }

        .navbar-brand {
            font-size: 1.5rem;
        }

        .product-image-container {
            height: 180px;
        }

        .card-body {
            padding: 1rem;
        }

        .offcanvas-custom {
            border-radius: 0;
            width: 85% !important;
        }
    }

</style>

<!-- Loading State -->
@if (ProductList == null || ProductList.Count == 0)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 70vh;">
        <div class="text-center">
            <div class="spinner mb-3"></div>
            <p class="text-muted">Loading plants...</p>
        </div>
    </div>
}
else
{
    <!-- Enhanced Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom mb-0 sticky-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="fas fa-leaf me-2"></i>Plantify-SmartGrow
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <!-- Show All button -->
                    <li class="nav-item">
                        <button class="btn category-btn me-2 mb-1"
                                @onclick="() => OnNavCategorySelected(null, null)">
                            <i class="fas fa-home me-1"></i> Show All
                        </button>
                    </li>

                    @foreach (var category in CategoryDict.Keys)
                    {
                        <li class="nav-item dropdown">
                            <button class="btn category-btn dropdown-toggle me-2 mb-1"
                                    type="button"
                                    @onclick="() => ToggleDropdown(category)">
                                <i class="fas fa-seedling me-1"></i> @category
                            </button>
                            <div class="dropdown-menu @(OpenDropdown == category ? "show" : "")">
                                <button class="dropdown-item fw-bold" @onclick="() => OnNavCategorySelected(category, null)">
                                    Show All @category
                                </button>
                                <div class="dropdown-divider"></div>
                                @foreach (var sub in CategoryDict[category])
                                {
                                    <button class="dropdown-item"
                                            @onclick="() => OnNavCategorySelected(category, sub)">
                                        <i class="fas fa-folder me-1"></i> @sub
                                    </button>
                                }
                            </div>
                        </li>
                    }
                </ul>

                <!-- Cart and Checkout Buttons -->
                <div class="d-flex ms-auto">
                    <button class="btn btn-cart text-white me-2 position-relative" type="button"
                            @onclick="OpenCartOffcanvas">
                        <i class="fas fa-shopping-cart me-1"></i> Cart
                        @if ((cartItem?.Plants?.Count ?? 0) > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger pulse">
                                @(cartItem?.Plants?.Count ?? 0)
                                <span class="visually-hidden">items in cart</span>
                            </span>
                        }
                    </button>
                    <button class="btn btn-checkout text-white" type="button"
                            @onclick="OpenCheckoutOffcanvas">
                        <i class="fas fa-credit-card me-1"></i> Checkout
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="hero-section text-center">
        <div class="container">
            <h1 class="display-5 fw-bold mb-3">Discover Beautiful Plants</h1>
            <p class="lead mb-4">Bring nature indoors with our premium selection</p>

            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="input-group input-group-lg shadow-sm">
                        <input type="text" class="form-control border-0" placeholder="Search for plants..." style="border-radius: 12px 0 0 12px;">
                        <button class="btn btn-warning border-0 text-white" style="border-radius: 0 12px 12px 0;">
                            <i class="fas fa-search me-1"></i> Search
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-4">
        <!-- Filter Info -->
        @if (!string.IsNullOrEmpty(selectedCategory) || !string.IsNullOrEmpty(selectedSubCategory))
        {
            <div class="alert alert-light fade-in mb-4" style="border-radius: 12px; border-left: 4px solid var(--primary);">
                <h6 class="mb-0 d-flex align-items-center">
                    <i class="fas fa-filter me-2 text-primary"></i>
                    Showing:
                    @if (!string.IsNullOrEmpty(selectedSubCategory))
                    {
                        <span class="badge bg-primary ms-2">@selectedCategory → @selectedSubCategory</span>
                    }
                    else if (!string.IsNullOrEmpty(selectedCategory))
                    {
                        <span class="badge bg-primary ms-2">@selectedCategory</span>
                    }
                    <small class="ms-2 text-muted">(@FilteredProducts.Count() products found)</small>
                </h6>
            </div>
        }

        <div class="row">
            <!-- Enhanced Product Grid -->
            <div class="col-12">
                <div class="row g-4">
                    @foreach (var item in FilteredProducts)
                    {
                        <div class="col-md-6 col-lg-4 col-xl-3 fade-in">
                            <div class="card product-card h-100">
                                <div class="product-image-container">
                                    <img src="@item.ImageUrl" class="product-image" alt="@item.PlantName" />
                                    <div class="product-badge">Rs @item.Price</div>
                                </div>
                                <div class="card-body">
                                    <h5 class="product-title">@item.PlantName</h5>
                                    <p class="product-category">
                                        <i class="fas fa-tag me-1"></i> @(item.Category ?? "General")
                                        @if (!string.IsNullOrEmpty(item.SubCategory))
                                        {
                                            <text> • @item.SubCategory</text>
                                        }
                                    </p>
                                    <p class="product-price">Rs @item.Price</p>
                                    <button class="btn btn-add-cart" @onclick="() => AddToCart(item)">
                                        <i class="fas fa-plus-circle me-1"></i> Add to Cart
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (!FilteredProducts.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">
                            <i class="fas fa-seedling"></i>
                        </div>
                        <h4 class="text-muted">No plants found</h4>
                        <p class="text-muted">Try adjusting your filters or search criteria</p>
                        <button class="btn btn-primary mt-3" @onclick="() => OnNavCategorySelected(null, null)">
                            <i class="fas fa-sync me-1"></i> Reset Filters
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Enhanced Cart Offcanvas -->
    <div class="offcanvas offcanvas-end offcanvas-custom @(isCartOpen ? "show" : "")"
         tabindex="-1"
         id="cartOffcanvas"
         aria-labelledby="cartOffcanvasLabel"
         style="@(isCartOpen ? "visibility: visible;" : "")">
        <div class="offcanvas-header offcanvas-header-custom">
            <h5 class="offcanvas-title fw-bold" id="cartOffcanvasLabel">
                <i class="fas fa-shopping-cart me-2"></i>Your Shopping Cart
            </h5>
            <button type="button" class="btn-close btn-close-white" @onclick="CloseCartOffcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-4">

            <div class="mb-4 p-3 rounded-3" style="background-color: rgba(46, 125, 50, 0.1);">
                <h6 class="fw-bold mb-2 text-dark">Cart Summary</h6>
                <div class="d-flex justify-content-between">
                    <span>Total Amount:</span>
                    <span class="fw-bold text-success">Rs @TotalAmount</span>
                </div>
            </div>

            @if (cartItem?.Plants == null || !cartItem.Plants.Any())
            {
                <div class="text-center py-5">
                    <div class="empty-state-icon mb-3">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <h5 class="text-muted">Your cart is empty</h5>
                    <p class="text-muted small">Add some plants to get started!</p>
                </div>
            }
            else
            {
                <div class="cart-items">
                    @foreach (var product in cartItem.Plants)
                    {
                        <div class="cart-item">
                            <div class="card-body p-3">
                                <div class="row align-items-center">
                                    <div class="col-3">
                                        <img src="@product.ImageUrl" class="img-fluid rounded-3" style="height: 60px; width: 60px; object-fit: cover;" />
                                    </div>
                                    <div class="col-6">
                                        <h6 class="mb-1 fw-bold">@product.PlantName</h6>
                                        <small class="text-success fw-bold">Rs @product.Price</small>
                                    </div>
                                    <div class="col-3 text-end">
                                        <div class="quantity-controls">
                                            <button class="quantity-btn quantity-btn-decrease"
                                                    @onclick="() => DecreaseQuantity(!string.IsNullOrEmpty(product.ProID) ? product.ProID : product.Id)"
                                                    title="Remove one item">
                                                −
                                            </button>
                                            <div class="quantity-display">@product.Quantity</div>
                                            <button class="quantity-btn quantity-btn-increase"
                                                    @onclick="() => IncreaseQuantity(!string.IsNullOrEmpty(product.ProID) ? product.ProID : product.Id)"
                                                    title="Add one more">
                                                +
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Enhanced Go to Checkout Button -->
                <div class="mt-4">
                    <button class="btn btn-checkout text-white w-100 py-3" @onclick="GoToCheckout">
                        <i class="fas fa-arrow-right me-2"></i> Proceed to Checkout
                    </button>
                </div>
            }

        </div>
    </div>

    <!-- Backdrop for offcanvas -->
    @if (isCartOpen)
    {
        <div class="offcanvas-backdrop fade show" @onclick="CloseCartOffcanvas"></div>
    }

    <!-- Enhanced Checkout Offcanvas -->
    <div class="offcanvas offcanvas-end offcanvas-custom @(isCheckoutOpen ? "show" : "")"
         tabindex="-1"
         id="checkoutOffcanvas"
         aria-labelledby="checkoutOffcanvasLabel"
         style="@(isCheckoutOpen ? "visibility: visible;" : "")">
        <div class="offcanvas-header offcanvas-header-custom">
            <h5 class="offcanvas-title fw-bold" id="checkoutOffcanvasLabel">
                <i class="fas fa-credit-card me-2"></i>Secure Checkout
            </h5>
            <button type="button" class="btn-close btn-close-white" @onclick="CloseCheckoutOffcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-4">

            <!-- Enhanced Order Summary -->
            <div class="order-summary mb-4">
                <h6 class="fw-bold mb-3">Order Summary</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span>Items:</span>
                    <span class="fw-bold">@(cartItem?.Plants?.Count ?? 0)</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Total Amount:</span>
                    <span class="fw-bold fs-5">Rs @FinalAmount</span>
                </div>
            </div>

            <!-- Enhanced Checkout Form -->
            <div class="checkout-form">
                <form>
                    <!-- Personal Information -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="fas fa-user me-2"></i>Personal Information
                        </h6>
                        <div class="row g-3">
                            <div class="col-6">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="First Name*" @bind="checkoutForm.FirstName" required />
                            </div>
                            <div class="col-6">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="Last Name*" @bind="checkoutForm.LastName" required />
                            </div>
                            <div class="col-12">
                                <input type="email" class="form-control form-control-custom"
                                       placeholder="Email Address*" @bind="checkoutForm.Email" required />
                            </div>
                            <div class="col-12">
                                <input type="tel" class="form-control form-control-custom"
                                       placeholder="Phone Number*" @bind="checkoutForm.Phone" required />
                            </div>
                        </div>
                    </div>

                    <!-- Address Information -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="fas fa-home me-2"></i>Shipping Address
                        </h6>
                        <div class="row g-3">
                            <div class="col-12">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="Street Address*" @bind="checkoutForm.Address" required />
                            </div>
                            <div class="col-8">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="City*" @bind="checkoutForm.City" required />
                            </div>
                            <div class="col-4">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="Postal Code" @bind="checkoutForm.PostalCode" />
                            </div>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="fas fa-credit-card me-2"></i>Payment Method
                        </h6>
                        <div class="row g-2">
                            <div class="col-12">
                                <div class="form-check p-3 rounded-3" style="background-color: rgba(102, 126, 234, 0.1);">
                                    <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard"
                                           value="Credit/Debit Card"
                                           @onchange="@(() => checkoutForm.PaymentMethod = "Credit/Debit Card")"
                                           checked="@(checkoutForm.PaymentMethod == "Credit/Debit Card")" />
                                    <label class="form-check-label fw-bold" for="creditCard">
                                        Credit Card / Debit Card (5% GST)
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-check p-3 rounded-3" style="background-color: rgba(40, 167, 69, 0.1);">
                                    <input class="form-check-input" type="radio" name="paymentMethod" id="cashOnDelivery"
                                           value="Cash on Delivery"
                                           @onchange="@(() => checkoutForm.PaymentMethod = "Cash on Delivery")"
                                           checked="@(checkoutForm.PaymentMethod == "Cash on Delivery")" />
                                    <label class="form-check-label fw-bold" for="cashOnDelivery">
                                        Cash on Delivery (15% GST)
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Enhanced Order Total -->
                    <div class="mb-4 p-3 rounded-3" style="background-color: rgba(248, 249, 250, 0.8); border: 2px solid #e9ecef;">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <span class="fw-bold">Rs @TotalAmount</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>GST (@(checkoutForm.PaymentMethod == "Cash on Delivery" ? "15%" : "5%")):</span>
                            <span class="fw-bold">Rs @(TotalAmount * (checkoutForm.PaymentMethod == "Cash on Delivery" ? 0.15m : 0.05m))</span>
                        </div>
                        <hr class="my-2">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold fs-5">Final Total:</span>
                            <span class="fw-bold fs-5 text-success">Rs @(TotalAmount + (TotalAmount * (checkoutForm.PaymentMethod == "Cash on Delivery" ? 0.15m : 0.05m)))</span>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <button type="button" class="btn btn-checkout w-100 py-3" @onclick="ProcessCheckout">
                        <i class="fas fa-check-circle me-2"></i> Complete Your Order
                    </button>
                </form>
            </div>

        </div>
    </div>

    <!-- Backdrop for checkout offcanvas -->
    @if (isCheckoutOpen)
    {
        <div class="offcanvas-backdrop fade show" @onclick="CloseCheckoutOffcanvas"></div>
    }

    <br />
    <br />

    <!-- Footer Section -->
    <footer class="footer">
        <div class="container">
            <div class="row">

                <!-- Logo + Social -->
                <div class="col-md-3 mb-4">
