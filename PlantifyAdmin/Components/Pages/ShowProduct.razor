@code {
    private List<PlantModel> ProductList = new();
    private Dictionary<string, List<string>> CategoryDict = new();
    private string? selectedCategory;
    private string? selectedSubCategory;
    private string? OpenDropdown;
    private bool isCartOpen = false;
    private bool isCheckoutOpen = false;

    // Checkout Form Model
    private CheckoutFormModel checkoutForm = new();

    public class CheckoutFormModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Address { get; set; } = "";
        public string City { get; set; } = "";
        public string PostalCode { get; set; } = "";
        public string PaymentMethod { get; set; } = "Credit/Debit Card";
    }

    // Fixed: Initialize cartItem with Plants list properly
    private CartModel cartItem = new() { Plants = new List<PlantModel>() };
    private string SelectedPaymentMethod = "Cash";

    private int TotalAmount => cartItem?.Plants?.Sum(p => (int)p.Price * p.Quantity) ?? 0;
    private decimal GstAmount => TotalAmount * (SelectedPaymentMethod == "Cash" ? 0.15m : 0.05m);
    private decimal FinalAmount => TotalAmount + GstAmount;

    private IEnumerable<PlantModel> FilteredProducts =>
        ProductList.Where(p =>
            (string.IsNullOrEmpty(selectedCategory) || p.Category == selectedCategory) &&
            (string.IsNullOrEmpty(selectedSubCategory) || p.SubCategory == selectedSubCategory));

    protected override async Task OnInitializedAsync()
    {
        ProductList = await productService.GetProductsAsync();

        // Build categories and subcategories
        CategoryDict = ProductList
            .GroupBy(p => p.Category ?? "Others")
            .ToDictionary(
                g => g.Key,
                g => g.Select(p => p.SubCategory ?? "General").Distinct().ToList()
            );

        // Ensure cartItem is properly initialized
        if (cartItem?.Plants == null)
        {
            cartItem = new CartModel { Plants = new List<PlantModel>() };
        }
    }

    private void ToggleDropdown(string category)
    {
        if (OpenDropdown == category)
            OpenDropdown = null;
        else
            OpenDropdown = category;
    }

    private void OnNavCategorySelected(string? category, string? subCategory)
    {
        selectedCategory = category;
        selectedSubCategory = subCategory;
        OpenDropdown = null; // close dropdown
    }

    // Fixed: AddToCart method - simplified and working version
    private void AddToCart(PlantModel product)
    {
        if (product == null)
        {
            return;
        }

        // Ensure cartItem and Plants list are initialized
        cartItem ??= new CartModel { Plants = new List<PlantModel>() };
        cartItem.Plants ??= new List<PlantModel>();

        // Use ProID as primary identifier, but ensure we have an ID
        var productId = !string.IsNullOrEmpty(product.ProID) ? product.ProID : product.Id;

        if (string.IsNullOrEmpty(productId))
        {
            // Generate a temporary ID if both are null
            productId = Guid.NewGuid().ToString();
        }

        // Check if item already exists in cart
        var existingItem = cartItem.Plants.FirstOrDefault(x =>
            (!string.IsNullOrEmpty(x.ProID) && x.ProID == product.ProID) ||
            (!string.IsNullOrEmpty(x.Id) && x.Id == product.Id));

        if (existingItem != null)
        {
            // Item already exists, increase quantity
            existingItem.Quantity++;
        }
        else
        {
            // Create a new cart item (copy the product)
            var newCartItem = new PlantModel
            {
                ProID = !string.IsNullOrEmpty(product.ProID) ? product.ProID : productId,
                Id = !string.IsNullOrEmpty(product.Id) ? product.Id : productId, // Ensure Id is not null
                PlantName = product.PlantName,
                ImageUrl = product.ImageUrl,
                Description = product.Description,
                Category = product.Category,
                SubCategory = product.SubCategory,
                BusinessId = product.BusinessId,
                Price = product.Price,
                Quantity = 1
            };

            cartItem.Plants.Add(newCartItem);
        }

        StateHasChanged();
    }

    // Replace your existing ProcessCheckout method with this corrected version:
    private async Task ProcessCheckout()
    {
        // Validate required fields
        if (string.IsNullOrWhiteSpace(checkoutForm.FirstName) ||
            string.IsNullOrWhiteSpace(checkoutForm.LastName) ||
            string.IsNullOrWhiteSpace(checkoutForm.Email) ||
            string.IsNullOrWhiteSpace(checkoutForm.Phone) ||
            string.IsNullOrWhiteSpace(checkoutForm.Address) ||
            string.IsNullOrWhiteSpace(checkoutForm.City))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please fill in all required fields.");
            return;
        }

        try
        {
            var userId = "demo-user";

            if (cartItem?.Plants != null)
            {
                foreach (var plant in cartItem.Plants)
                {
                    // Fix the null ID issue
                    if (string.IsNullOrEmpty(plant.Id))
                    {
                        plant.Id = !string.IsNullOrEmpty(plant.ProID) ? plant.ProID : Guid.NewGuid().ToString();
                    }
                    if (string.IsNullOrEmpty(plant.ProID))
                    {
                        plant.ProID = plant.Id;
                    }
                }

                cartItem.UserId = userId;
                await CartService.AddCardToCollection(userId);
                await CartService.AddPlantToCartAsync(userId, cartItem.Plants);
                cartItem.Plants?.Clear();
            }

            checkoutForm = new CheckoutFormModel();
            CloseCheckoutOffcanvas();
            await JSRuntime.InvokeVoidAsync("alert", "Order placed successfully! Thank you for your purchase.");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error processing checkout: " + ex.Message);
        }
    }

    // Update your DecreaseQuantity method:
    private void DecreaseQuantity(string? productId)
    {
        if (string.IsNullOrEmpty(productId) || cartItem?.Plants == null)
        {
            return;
        }

        // Find item by ProID primarily, then by Id
        var item = cartItem.Plants.FirstOrDefault(p =>
            (!string.IsNullOrEmpty(p.ProID) && p.ProID == productId) ||
            (!string.IsNullOrEmpty(p.Id) && p.Id == productId));

        if (item != null)
        {
            if (item.Quantity > 1)
            {
                item.Quantity--;
            }
            else
            {
                // Remove item if quantity becomes 0 or less
                cartItem.Plants.Remove(item);
            }

            StateHasChanged();
        }
    }

    // Update your IncreaseQuantity method:
    private void IncreaseQuantity(string? productId)
    {
        if (string.IsNullOrEmpty(productId) || cartItem?.Plants == null)
        {
            return;
        }

        // Find item by ProID primarily, then by Id
        var item = cartItem.Plants.FirstOrDefault(p =>
            (!string.IsNullOrEmpty(p.ProID) && p.ProID == productId) ||
            (!string.IsNullOrEmpty(p.Id) && p.Id == productId));

        if (item != null)
        {
            item.Quantity++;
            StateHasChanged();
        }
    }

    private void SelectPaymentMethod(string method) => SelectedPaymentMethod = method;

    private void OpenCartOffcanvas()
    {
        isCartOpen = true;
        isCheckoutOpen = false; // Close checkout if open
        StateHasChanged();
    }

    private void CloseCartOffcanvas()
    {
        isCartOpen = false;
        StateHasChanged();
    }

    private void OpenCheckoutOffcanvas()
    {
        isCheckoutOpen = true;
        isCartOpen = false; // Close cart if open
        StateHasChanged();
    }

    private void CloseCheckoutOffcanvas()
    {
        isCheckoutOpen = false;
        StateHasChanged();
    }

    private void GoToCheckout()
    {
        CloseCartOffcanvas();
        OpenCheckoutOffcanvas();
    }

    private async Task Checkout()
    {
        var userId = "demo-user";
        cartItem.UserId = userId;
        await CartService.AddCardToCollection(userId);
        await CartService.AddPlantToCartAsync(userId, cartItem.Plants);
        cartItem.Plants?.Clear();
        CloseCartOffcanvas(); // Close cart after checkout
        StateHasChanged();
    }


