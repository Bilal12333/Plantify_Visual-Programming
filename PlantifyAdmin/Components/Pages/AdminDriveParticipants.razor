@page "/admin/drive-participants"
@using Entities
@using DAL
@inject IParticipantService ParticipantService
@inject IPlantationService PlantationService
@rendermode InteractiveServer
@layout AdminLayout
@inject IJSRuntime JSRuntime


<PageTitle>Drive Participants</PageTitle>

<div class="participants-page">

    <!-- HEADER -->
    <div class="page-header">
        <div>
            <h1>👥 Drive Participants</h1>
            <p>View and manage participants across all plantation drives</p>
        </div>
        <div class="header-actions">
            <button class="export-btn" @onclick="ExportCsv" disabled="@(FilteredParticipants == null || !FilteredParticipants.Any())">
                📥 Export CSV
            </button>
        </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar">
        <div class="search-box">
            <span>🔍</span>
            <input type="text"
                   placeholder="Search by name, email or phone..."
                   @bind="SearchQuery"
                   @bind:event="oninput"
                   class="search-input" />
        </div>

        <select class="drive-select" @bind="SelectedDriveId">
            <option value="">🌱 All Drives</option>
            @if (Drives != null)
            {
                @foreach (var drive in Drives)
                {
                    <option value="@drive.Id">@drive.Title</option>
                }
            }
        </select>

        <button class="clear-btn" @onclick="ClearFilters">✕ Clear</button>
    </div>

    <!-- STATS ROW -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon">👥</div>
            <div>
                <h3>@(AllParticipants?.Count ?? 0)</h3>
                <p>Total Participants</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🌱</div>
            <div>
                <h3>@(Drives?.Count ?? 0)</h3>
                <p>Total Drives</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📅</div>
            <div>
                <h3>@(AllParticipants?.Count(p => p.JoinedAt.Date == DateTime.UtcNow.Date) ?? 0)</h3>
                <p>Joined Today</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🔍</div>
            <div>
                <h3>@(FilteredParticipants?.Count ?? 0)</h3>
                <p>Showing</p>
            </div>
        </div>
    </div>

    <!-- TABLE -->
    @if (IsLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading participants...</p>
        </div>
    }
    else if (FilteredParticipants == null || !FilteredParticipants.Any())
    {
        <div class="empty-state">
            <div style="font-size:64px;">👥</div>
            <h3>No participants found</h3>
            <p>Try adjusting your filters or search query.</p>
        </div>
    }
    else
    {
        <div class="table-container">
            <table class="participants-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Drive</th>
                        <th>Joined At</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                    }
                    @foreach (var p in FilteredParticipants)
                    {
                        <tr>
                            <td class="index-col">@index</td>
                            <td>
                                <div class="participant-name">
                                    <div class="name-avatar">
                                        @p.FirstName[0]@p.LastName[0]
                                    </div>
                                    <span>@p.FirstName @p.LastName</span>
                                </div>
                            </td>
                            <td><a href="mailto:@p.Email" class="email-link">@p.Email</a></td>
                            <td>@p.PhoneNumber</td>
                            <td>
                                <span class="drive-badge">@p.DriveTitle</span>
                            </td>
                            <td class="date-col">@p.JoinedAt.ToString("MMM dd, yyyy · hh:mm tt")</td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    }

</div>

<style>
    .participants-page {
        padding: 32px;
        background: #f4f7f3;
        min-height: 100vh;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }

        .page-header h1 {
            font-size: 32px;
            font-weight: 900;
            color: #1b5e20;
            margin: 0 0 6px 0;
        }

        .page-header p {
            color: #6b7280;
            margin: 0;
        }

    .export-btn {
        background: linear-gradient(135deg, #43a047, #2e7d32);
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .export-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(67,160,71,0.3);
        }

        .export-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .filter-bar {
        background: white;
        border-radius: 20px;
        padding: 20px 24px;
        margin-bottom: 24px;
        display: flex;
        gap: 14px;
        align-items: center;
        flex-wrap: wrap;
        box-shadow: 0 5px 20px rgba(0,0,0,0.04);
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 12px 18px;
        flex: 1;
        min-width: 200px;
    }

    .search-input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 15px;
        color: #374151;
        width: 100%;
    }

    .drive-select {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 12px 18px;
        font-size: 15px;
        font-weight: 600;
        color: #374151;
        background: #f9fafb;
        outline: none;
        cursor: pointer;
        min-width: 200px;
    }

    .clear-btn {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        padding: 12px 18px;
        border-radius: 14px;
        font-weight: 600;
        color: #374151;
        cursor: pointer;
        transition: 0.2s;
    }

        .clear-btn:hover {
            background: #f3f4f6;
        }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.04);
    }

    .stat-icon {
        font-size: 32px;
        width: 56px;
        height: 56px;
        background: #f0fdf4;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-card h3 {
        font-size: 28px;
        font-weight: 900;
        color: #1b5e20;
        margin: 0 0 4px 0;
    }

    .stat-card p {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
    }

    .table-container {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .participants-table {
        width: 100%;
        border-collapse: collapse;
    }

        .participants-table thead tr {
            background: #f0fdf4;
            border-bottom: 2px solid #e5e7eb;
        }

        .participants-table th {
            padding: 16px 20px;
            text-align: left;
            font-size: 13px;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .participants-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f0fdf4;
            font-size: 15px;
            color: #374151;
        }

        .participants-table tbody tr:hover {
            background: #f9fafb;
        }

        .participants-table tbody tr:last-child td {
            border-bottom: none;
        }

    .index-col {
        color: #9ca3af !important;
        font-weight: 700;
        width: 50px;
    }

    .participant-name {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .name-avatar {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, #43a047, #2e7d32);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 14px;
        flex-shrink: 0;
        text-transform: uppercase;
    }

    .email-link {
        color: #2e7d32;
        text-decoration: none;
        font-weight: 600;
    }

        .email-link:hover {
            text-decoration: underline;
        }

    .drive-badge {
        background: #f0fdf4;
        color: #1b5e20;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
    }

    .date-col {
        color: #9ca3af !important;
        font-size: 13px !important;
        white-space: nowrap;
    }

    .loading-state, .empty-state {
        text-align: center;
        padding: 80px;
        color: #6b7280;
        background: white;
        border-radius: 24px;
    }

        .empty-state h3 {
            font-size: 22px;
            font-weight: 700;
            color: #374151;
            margin: 16px 0 8px;
        }

    .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #dcfce7;
        border-top-color: #2e7d32;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 20px;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

@code {
    private List<DriveParticipant>? AllParticipants;
    private List<Plantation>? Drives;
    private bool IsLoading = true;
    private string SearchQuery = "";
    private string SelectedDriveId = "";

    protected override async Task OnInitializedAsync()
    {
        Drives = PlantationService.GetAll();
        AllParticipants = await ParticipantService.GetAllAsync();
        IsLoading = false;
    }

    private List<DriveParticipant>? FilteredParticipants
    {
        get
        {
            if (AllParticipants == null) return null;

            var result = AllParticipants.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SelectedDriveId))
                result = result.Where(p => p.DriveId == SelectedDriveId);

            if (!string.IsNullOrWhiteSpace(SearchQuery))
                result = result.Where(p =>
                    (p.FirstName + " " + p.LastName).Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.Email.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    p.PhoneNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

            return result.ToList();
        }
    }

    private void ClearFilters()
    {
        SearchQuery = "";
        SelectedDriveId = "";
    }

    private async Task ExportCsv()
    {
        if (FilteredParticipants == null || !FilteredParticipants.Any()) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Name,Email,Phone,Drive,Joined At");

        foreach (var p in FilteredParticipants)
        {
            sb.AppendLine($"{p.FirstName} {p.LastName},{p.Email},{p.PhoneNumber},{p.DriveTitle},{p.JoinedAt:yyyy-MM-dd HH:mm}");
        }

        var fileName = string.IsNullOrWhiteSpace(SelectedDriveId)
            ? "all-participants.csv"
            : $"{FilteredParticipants.FirstOrDefault()?.DriveTitle?.Replace(" ", "-")}-participants.csv";

        await JSRuntime.InvokeVoidAsync("downloadCsv", fileName, sb.ToString());
    }
}