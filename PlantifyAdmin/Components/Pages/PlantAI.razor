@page "/plant-ai"
@attribute [Authorize]
@layout UserMainLayout
@rendermode InteractiveServer
@inject GroqService GroqService
@inject IJSRuntime JSRuntime

<PageTitle>Plant AI Assistant</PageTitle>

<div class="ai-page-layout">

    <!-- SIDEBAR -->
    <aside class="ai-sidebar">
        <div class="sidebar-section">
            <p class="sidebar-title">NAVIGATION</p>
            <NavLink class="sidebar-link" href="/dashboard">
                <span class="sidebar-icon">🏠</span> Dashboard
            </NavLink>
            <NavLink class="sidebar-link" href="/plantation-drives">
                <span class="sidebar-icon">🌱</span> Plantation Drives
            </NavLink>
            <NavLink class="sidebar-link" href="/plant-ai" Match="NavLinkMatch.All">
                <span class="sidebar-icon">🤖</span> Plant AI Assistant
            </NavLink>
            <NavLink class="sidebar-link" href="/disease-detection">
                <span class="sidebar-icon">🔬</span> Disease Detection
            </NavLink>
        </div>

        <div class="sidebar-section">
            <p class="sidebar-title">QUICK TOPICS</p>
            <div class="topic-chips">
                <button class="topic-chip" @onclick='() => SetQuestion("How to water indoor plants?")'>💧 Watering Tips</button>
                <button class="topic-chip" @onclick='() => SetQuestion("How to treat plant diseases?")'>🦠 Disease Treatment</button>
                <button class="topic-chip" @onclick='() => SetQuestion("Best fertilizer for tomatoes?")'>🌱 Fertilizers</button>
                <button class="topic-chip" @onclick='() => SetQuestion("How to grow plants from seeds?")'>🌿 Growing Tips</button>
                <button class="topic-chip" @onclick='() => SetQuestion("How to deal with plant pests?")'>🐛 Pest Control</button>
            </div>
        </div>

        <div class="sidebar-section">
            <p class="sidebar-title">ABOUT</p>
            <div class="about-card">
                <p>🤖 Powered by <strong>Llama 3.1</strong> via Groq</p>
                <p>🌿 Specialized in plant care, diseases, and gardening</p>
                <p>⚡ Fast AI responses</p>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <main class="ai-main">

        <!-- HERO -->
        <div class="ai-hero">
            <div class="ai-hero-text">
                <span class="hero-badge">🤖 AI Powered</span>
                <h1>Plant AI Assistant</h1>
                <p>Ask anything about plants, gardening, diseases, and care tips.</p>
            </div>
            <div class="ai-hero-icon">🌿</div>
        </div>

        <!-- CHAT CONTAINER -->
        <div class="ai-chat-container">

            <div class="ai-chat-box" id="chatBox">

                @if (!Messages.Any())
                {
                    <div class="empty-chat">
                        <div class="empty-icon">🌱</div>
                        <h3>Start chatting with Plant AI</h3>
                        <p>Ask any question about plants and gardening</p>
                        <div class="suggestion-grid">
                            <button class="suggestion-btn" @onclick='() => SetQuestion("What are common tomato diseases?")'>🍅 Common tomato diseases?</button>
                            <button class="suggestion-btn" @onclick='() => SetQuestion("How often should I water succulents?")'>🌵 How to water succulents?</button>
                            <button class="suggestion-btn" @onclick='() => SetQuestion("Best indoor plants for beginners?")'>🪴 Best indoor plants?</button>
                            <button class="suggestion-btn" @onclick='() => SetQuestion("How to make compost at home?")'>♻️ How to make compost?</button>
                        </div>
                    </div>
                }

                @foreach (var msg in Messages)
                {
                    <div class="chat-wrapper @(msg.IsUser ? "user" : "ai")">
                        @if (!msg.IsUser)
                        {
                            <div class="ai-avatar">🌿</div>
                        }
                        <div class="chat-bubble">
                            @((MarkupString)FormatMessage(msg.Text))
                        </div>
                        @if (msg.IsUser)
                        {
                            <div class="user-avatar">👤</div>
                        }
                    </div>
                }

                @if (IsLoading)
                {
                    <div class="chat-wrapper ai">
                        <div class="ai-avatar">🌿</div>
                        <div class="chat-bubble typing-bubble">
                            <div class="typing-dots">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </div>
                    </div>
                }

            </div>

            <div class="ai-input-section">
                <input class="ai-input"
                       placeholder="Ask your plant question..."
                       @bind="UserQuestion"
                       @bind:event="oninput"
                       @onkeypress="HandleKeyPress" />
                <button class="ai-send-btn" @onclick="AskAI" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span>⏳</span>
                    }
                    else
                    {
                        <span>Send 🌿</span>
                    }
                </button>
            </div>

        </div>

    </main>
</div>

<style>
    .ai-page-layout {
        display: flex;
        min-height: 100vh;
        background: #f4f7f3;
    }

    /* SIDEBAR */
    .ai-sidebar {
        width: 270px;
        background: white;
        border-right: 1px solid #e5e7eb;
        padding: 24px 18px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        height: 100vh;
        position: sticky;
        top: 0;
        overflow-y: auto;
    }

    .sidebar-section {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .sidebar-title {
        font-size: 13px;
        font-weight: 700;
        color: #9ca3af;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        border: none;
        background: transparent;
        text-align: left;
        padding: 12px 16px;
        border-radius: 14px;
        font-weight: 600;
        color: #374151;
        transition: 0.3s;
        text-decoration: none;
        width: 100%;
    }

        .sidebar-link:hover {
            background: #f3f4f6;
        }

        .sidebar-link.active {
            background: #e8f5e9;
            color: #2e7d32;
            font-weight: 700;
        }

    .sidebar-icon {
        font-size: 18px;
        margin-right: 10px;
        width: 24px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* TOPIC CHIPS */
    .topic-chips {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .topic-chip {
        background: #f0fdf4;
        border: 1px solid #c8e6c9;
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 13px;
        font-weight: 600;
        color: #2e7d32;
        text-align: left;
        cursor: pointer;
        transition: 0.2s;
    }

        .topic-chip:hover {
            background: #dcfce7;
            transform: translateX(4px);
        }

    /* ABOUT CARD */
    .about-card {
        background: #f0fdf4;
        border-radius: 14px;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .about-card p {
            font-size: 13px;
            color: #374151;
            margin: 0;
        }

    /* MAIN */
    .ai-main {
        flex: 1;
        padding: 30px;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* HERO */
    .ai-hero {
        background: linear-gradient(135deg, #1b5e20, #2e7d32, #43a047);
        border-radius: 24px;
        padding: 40px 50px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .hero-badge {
        background: rgba(255,255,255,0.2);
        padding: 8px 18px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 14px;
    }

    .ai-hero-text h1 {
        font-size: 42px;
        font-weight: 900;
        color: white;
        margin-bottom: 10px;
    }

    .ai-hero-text p {
        font-size: 17px;
        color: rgba(255,255,255,0.85);
        margin: 0;
    }

    .ai-hero-icon {
        font-size: 100px;
        opacity: 0.3;
    }

    /* CHAT CONTAINER */
    .ai-chat-container {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        flex: 1;
