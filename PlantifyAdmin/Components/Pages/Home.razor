    {
    // Disease Detection
    [Inject] private PlantDiseaseService PlantDiseaseService { get; set; } = default!;
    private bool ShowDiseaseModal = false;
    private string? DiseaseImagePreview;
    private Stream? SelectedImageStream;
    private string? SelectedImageName;
    private bool IsDetecting = false;
    private PlantDiseaseResult? DiseaseResult;

    private void OpenDiseaseModal()
    {
        ShowDiseaseModal = true;
        DiseaseResult = null;
        DiseaseImagePreview = null;
        SelectedImageStream = null;
    }

    private void CloseDiseaseModal()
    {
        ShowDiseaseModal = false;
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        SelectedImageName = file.Name;

        var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
        ms.Position = 0;
        SelectedImageStream = ms;

        // Preview
        ms.Position = 0;
        var buffer = new byte[ms.Length];
        await ms.ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        var ext = Path.GetExtension(file.Name).TrimStart('.');
        DiseaseImagePreview = $"data:image/{ext};base64,{base64}";

        ms.Position = 0;
        StateHasChanged();
    }

    private async Task DetectDisease()
    {
        if (SelectedImageStream == null) return;

        IsDetecting = true;
        DiseaseResult = null;
        StateHasChanged();

        SelectedImageStream.Position = 0;
        DiseaseResult = await PlantDiseaseService.PredictAsync(SelectedImageStream, SelectedImageName ?? "image.jpg");

        IsDetecting = false;
        StateHasChanged();
    }

    private string UserQuestion = "";

    private List<ChatMessage> Messages = new();
    public static class PlantValidator
    {
        private static readonly string[] AllowedKeywords =
        {
        "plant", "plants", "cactus", "leaf", "flower", "tree",
        "soil", "fertilizer", "watering", "disease", "garden",
        "botany", "succulent", "pest", "photosynthesis"
    };

        public static bool IsPlantRelated(string input)
        {
            if (string.IsNullOrWhiteSpace(input))
                return false;

            input = input.ToLower();

            return AllowedKeywords.Any(keyword => input.Contains(keyword));
        }
    }

    private async Task AskAI()
    {
        if (string.IsNullOrWhiteSpace(UserQuestion))
            return;

        Messages.Add(new ChatMessage
        {
            Text = UserQuestion,
            IsUser = true
        });

        var question = UserQuestion;

        UserQuestion = "";

        StateHasChanged();

        var response = await GroqService.AskPlantAssistant(question);

        Messages.Add(new ChatMessage
        {
            Text = response,
            IsUser = false
        });

        StateHasChanged();
    }

    public class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
    }
    private async Task ProcessCheckout()
    {
        // Validation - use warning toasts instead of alert()
        if (string.IsNullOrWhiteSpace(checkoutForm.FirstName) ||
            string.IsNullOrWhiteSpace(checkoutForm.LastName) ||
            string.IsNullOrWhiteSpace(checkoutForm.Email) ||
            string.IsNullOrWhiteSpace(checkoutForm.Phone) ||
            string.IsNullOrWhiteSpace(checkoutForm.Address) ||
            string.IsNullOrWhiteSpace(checkoutForm.City))
        {
            ToastService.Show("Please fill in all required fields.", "warning");
            return;
        }

        if (cartItem?.Plants == null || !cartItem.Plants.Any())
        {
            ToastService.Show("Your cart is empty.", "warning");
            return;
        }

        try
        {
            var userId = "demo-user";

            var order = new OrderModel
                {
                    UserId = userId,
                    FirstName = checkoutForm.FirstName,
                    LastName = checkoutForm.LastName,
                    Email = checkoutForm.Email,
                    Phone = checkoutForm.Phone,
                    Address = checkoutForm.Address,
                    City = checkoutForm.City,
                    PostalCode = checkoutForm.PostalCode,
                    PaymentMethod = checkoutForm.PaymentMethod,
                    SubTotal = TotalAmount,
                    Gst = checkoutForm.PaymentMethod == "Cash on Delivery"
                        ? TotalAmount * 0.15m
                        : TotalAmount * 0.05m,
                    FinalTotal = checkoutForm.PaymentMethod == "Cash on Delivery"
                        ? TotalAmount + (TotalAmount * 0.15m)
                        : TotalAmount + (TotalAmount * 0.05m),
                    Items = cartItem.Plants.Select(p => new PlantModel
                    {
                        Id = p.Id,
                        ProID = p.ProID,
                        PlantName = p.PlantName,
                        Price = p.Price,
                        Quantity = p.Quantity,
                        ImageUrl = p.ImageUrl
                    }).ToList()
                };

            await OrderService.SaveOrderAsync(order);
            await CartService.AddCardToCollection(userId);
            await CartService.AddPlantToCartAsync(userId, cartItem.Plants);


            // Send confirmation email
            try
            {
                await EmailService.SendOrderConfirmationAsync(order);
            }
            catch
            {
                // Don't block the user if email fails — order is already saved
            }

            cartItem.Plants.Clear();
            checkoutForm = new CheckoutFormModel();
            CloseCheckoutOffcanvas();

            ToastService.Show($"Order placed! Confirmation sent to {order.Email} 🌿", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.Show("Error processing checkout: " + ex.Message, "error");
        }
    }

    private void ShowStore()
    {
        SelectedTab = DashboardTab.Store;
        StateHasChanged();
    }

