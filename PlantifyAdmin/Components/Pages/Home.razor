    // Cart and Checkout
    private bool isCartOpen;
    private bool isCheckoutOpen;
    private CartModel cartItem = new() { Plants = new List<PlantModel>() };

    // Category Navigation
    private List<PlantModel> ProductList = new();
    private string? selectedCategory;
    private string? selectedSubCategory;
    private Dictionary<string, List<string>> CategoryDict = new();
