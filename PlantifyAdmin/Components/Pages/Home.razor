@page "/dashboard"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization;
@inject IPlantationService PlantationService
@inject IPlantService PlantService
@inject ICartService CartService
@inject IOrderService OrderService
@inject GroqService GroqService
@inject IJSRuntime JSRuntime
@using PlantifyAdmin.Services
@rendermode InteractiveServer
@layout UserMainLayout
@inject ToastService ToastService
@inject EmailService EmailService

<PageTitle>Plantify Dashboard</PageTitle>

<div class="dashboard-layout">

    <!-- SIDEBAR -->
    <aside class="dashboard-sidebar">

        <!-- BRAND -->
        <div class="sidebar-brand">
            <div class="brand-icon">🌿</div>
            <div>
                <h2 class="brand-name">Plantify</h2>
                <p class="brand-tagline">Green Living Platform</p>
            </div>
        </div>

        <div class="sidebar-divider"></div>

        <!-- MANAGE -->
        <div class="sidebar-section">
            <p class="sidebar-title">
                <span class="title-line"></span>
                MANAGE
                <span class="title-line"></span>
            </p>
            <NavLink class="sidebar-link" href="/business/register">
                <span class="link-icon-wrap icon-blue">🏢</span>
                <span class="link-text">Business Registration</span>
            </NavLink>
            <NavLink class="sidebar-link" href="/business/products">
                <span class="link-icon-wrap icon-orange">📦</span>
                <span class="link-text">Manage Products</span>
            </NavLink>
            <NavLink class="sidebar-link" href="/admin/drives">
                <span class="link-icon-wrap icon-purple">🗂️</span>
                <span class="link-text">Admin Drives</span>
            </NavLink>
        </div>

        <div class="sidebar-divider"></div>

        <!-- STORE -->
        <div class="sidebar-section">
            <p class="sidebar-title">
                <span class="title-line"></span>
                STORE
                <span class="title-line"></span>
            </p>
            <button type="button"
                    class="sidebar-link @(SelectedTab == DashboardTab.Store ? "active" : "")"
                    @onclick="() => SetTab(DashboardTab.Store)">
                <span class="link-icon-wrap icon-green">🌿</span>
                <span class="link-text">Plantation Store</span>
                @if (SelectedTab == DashboardTab.Store)
                {
                    <span class="active-dot"></span>
                }
            </button>
            <NavLink class="sidebar-link" href="/plantation-drives">
                <span class="link-icon-wrap icon-teal">🌱</span>
                <span class="link-text">Plantation Drives</span>
            </NavLink>
        </div>

        <div class="sidebar-divider"></div>

        <!-- AI TOOLS -->
        <div class="sidebar-section">
            <p class="sidebar-title">
                <span class="title-line"></span>
                AI TOOLS
                <span class="title-line"></span>
            </p>
            <NavLink class="sidebar-link" href="/plant-ai">
                <span class="link-icon-wrap icon-indigo">🤖</span>
                <span class="link-text">Plant AI Assistant</span>
                <span class="new-badge">AI</span>
            </NavLink>
            <NavLink class="sidebar-link" href="/disease-detection">
                <span class="link-icon-wrap icon-red">🔬</span>
                <span class="link-text">Disease Detection</span>
                <span class="new-badge">AI</span>
            </NavLink>
        </div>

        <div class="sidebar-divider"></div>

        <!-- ILLUSTRATION -->
        <div class="sidebar-illustration">
            <div class="illustration-text">
                <p class="illustration-title">🌍 Go Green Today</p>
                <p class="illustration-sub">Plant a tree, save the planet</p>
            </div>
            <svg viewBox="0 0 260 100" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="130" cy="92" rx="130" ry="14" fill="#a5d6a7" opacity="0.4" />
                <rect x="60" y="55" width="8" height="40" rx="4" fill="#4caf50" />
                <ellipse cx="64" cy="48" rx="18" ry="22" fill="#66bb6a" />
                <ellipse cx="55" cy="56" rx="12" ry="15" fill="#81c784" />
                <rect x="120" y="35" width="10" height="58" rx="5" fill="#388e3c" />
                <ellipse cx="125" cy="26" rx="24" ry="28" fill="#4caf50" />
                <ellipse cx="112" cy="38" rx="16" ry="18" fill="#66bb6a" />
                <rect x="185" y="48" width="7" height="46" rx="3" fill="#4caf50" />
                <ellipse cx="188" cy="42" rx="16" ry="20" fill="#81c784" />
                <ellipse cx="178" cy="52" rx="11" ry="13" fill="#a5d6a7" />
            </svg>
        </div>

    </aside>

    <!-- MAIN -->
    <main class="dashboard-main">
        <!-- HERO SECTION -->
        <section class="hero-banner">

            <div class="hero-overlay"></div>

            <div class="hero-content">

                <span class="hero-badge">
                    🌱 AI Powered Plantation Platform
                </span>

                <h1>
                    Grow Your Dream Garden With Plantify
                </h1>

                <p>
                    Buy plants, detect diseases using AI, and join plantation drives.
                </p>

                <div class="hero-buttons">

                    <button class="hero-primary-btn">
                        Explore Store
                    </button>

                    <button class="hero-secondary-btn">
                        Ask AI Assistant
                    </button>

                </div>

                <div class="hero-stats">

                    <div class="hero-stat-card">
                        <h3>500+</h3>
                        <p>Plants</p>
                    </div>

                    <div class="hero-stat-card">
                        <h3>120+</h3>
                        <p>Drives</p>
                    </div>

                    <div class="hero-stat-card">
                        <h3>24/7</h3>
                        <p>AI Support</p>
                    </div>

                </div>

            </div>

        </section>



        <div class="topbar">

            <div>
                <h1>🌿Plantation Store</h1>
                <p>Discover plants, fertilizers and tools</p>
            </div>

            <div class="topbar-actions">

                <button class="cart-btn" @onclick="OpenCartOffcanvas">
                    🛒 Cart
                    <span class="cart-count">
                        @(cartItem?.Plants?.Count ?? 0)
                    </span>
                </button>

                <button class="checkout-btn"
                        @onclick="OpenCheckoutOffcanvas">
                    Checkout
                </button>



            </div>
        </div>


        @if (SelectedTab == DashboardTab.Store)
        {
            <link rel="stylesheet"
                  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

            <div class="store-nav">

                <button type="button"
                        class="category-btn @(StoreCategoryFilter is null ? "active" : "")"
                        @onclick='() => SetStoreCategory(null)'>

                    <i class="fas fa-leaf"></i>
                    Show Product
                </button>

                <button type="button"
                        class="category-btn @(StoreCategoryFilter == "Indoor Plants" ? "active" : "")"
                        @onclick='() => SetStoreCategory("Indoor Plants")'>

                    <i class="fas fa-seedling"></i>
                    Indoor
                </button>

                <button type="button"
                        class="category-btn @(StoreCategoryFilter == "Outdoor Plants" ? "active" : "")"
                        @onclick='() => SetStoreCategory("Outdoor Plants")'>

                    <i class="fas fa-sun"></i>
                    Outdoor
                </button>

                <button type="button"
                        class="category-btn @(StoreCategoryFilter == "Fertilizers" ? "active" : "")"
                        @onclick='() => SetStoreCategory("Fertilizers")'>

                    <i class="fas fa-spa"></i>
                    Fertilizers
                </button>

                <button type="button"
                        class="category-btn @(StoreCategoryFilter == "Tools" ? "active" : "")"
                        @onclick='() => SetStoreCategory("Tools")'>

                    <i class="fas fa-tools"></i>
                    Tools
                </button>

            </div>

            @if (StoreProducts == null)
            {
                <p>Loading products...</p>
            }
            else if (!FilteredStoreProducts.Any())
            {
                <p>No products found. Add products and they will appear here.</p>
            }
            else
            {
                <div class="store-product-grid">
                    @foreach (var item in FilteredStoreProducts)
                    {
                        <div class="product-card"
                             @onclick="() => OpenProductModal(item)"
                             style="cursor:pointer;">
                            <div class="product-image-container">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="product-image" alt="@item.PlantName" />
                                }
                                else
                                {
                                    <div class="product-image-fallback">🌿</div>
                                }
                                <div class="product-badge">Rs @item.Price</div>
                            </div>
                            <div class="product-card-body">
                                <h5 class="product-title">@item.PlantName</h5>
                                <p class="product-category">
                                    @(string.IsNullOrWhiteSpace(item.Category) ? "General" : item.Category)
                                    @if (!string.IsNullOrWhiteSpace(item.SubCategory))
                                    {
                                        <text> • @item.SubCategory</text>
                                    }
                                </p>
                                <p class="product-price">Rs @item.Price</p>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <p class="product-desc">@item.Description</p>
                                }
                                <button type="button"
                                        class="btn-add-cart"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => AddToCart(item)">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }

        }
        else
        {
            <section class="content-section">
                <h2>Join Plantation Drives</h2>
                <p>These drives are managed by the admin panel and published here for users.</p>

                @if (PlantationDrives == null)
                {
                    <p>Loading drives...</p>
                }
                else if (!PlantationDrives.Any())
                {
                    <p>No plantation drives found. Add a drive from `Add Events` and it will appear here.</p>
                }
                else
                {
                    <div class="drive-grid">
                        @foreach (var drive in PlantationDrives)
                        {
                            <article class="plantation-card">
                                <div class="card-header-modern">
                                    <h3 class="card-title-modern">@drive.Title</h3>
                                    <p class="card-organizer">Organized by @drive.OrganizedBy</p>
                                </div>

                                <div class="card-body-modern">
                                    <div class="info-item-modern">
                                        <div class="info-icon-modern">📍</div>
                                        <div class="info-content">
                                            <p class="info-label">Location</p>
                                            <p class="info-value">@drive.Location</p>
                                        </div>
                                    </div>

                                    <div class="info-item-modern">
                                        <div class="info-icon-modern">📅</div>
                                        <div class="info-content">
                                            <p class="info-label">Date</p>
                                            <p class="info-value">@drive.Date.ToString("dddd, MMMM dd, yyyy")</p>
                                        </div>
                                    </div>

                                    <div class="info-item-modern">
                                        <div class="info-icon-modern">🌱</div>
                                        <div class="info-content">
                                            <p class="info-label">Saplings Goal</p>
                                            <p class="info-value">@drive.TotalSaplings trees</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-footer-modern">
                                    <button type="button" class="join-btn-modern" @onclick='() => ShowJoinForm(drive.Id!)'>🤝 Join This Drive</button>
                                    <span class="participant-badge-modern">👥 @(drive.Participants?.Count ?? 0) participants</span>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }

        @if (ShowJoinPopup)
        {
            <div class="join-modal-backdrop" @onclick="CloseJoinForm">
                <div class="join-modal-card modal-modern" @onclick:stopPropagation="true">
                    <div class="modal-header-modern">
                        <h3>Join Plantation Drive</h3>
                        <p class="join-modal-subtitle">Enter your details to participate in this drive.</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(JoinError))
                    {
                        <p class="join-error">@JoinError</p>
                    }

                    <div class="join-form-grid">
                        <input class="join-input" placeholder="First name"
                               @bind="NewParticipant.FirstName"
                               @onclick:stopPropagation="true" />
                        <input class="join-input" placeholder="Last name"
                               @bind="NewParticipant.LastName"
                               @onclick:stopPropagation="true" />
                        <input class="join-input" type="email" placeholder="Email"
                               @bind="NewParticipant.Email"
                               @onclick:stopPropagation="true" />
                        <input class="join-input" type="tel" placeholder="Phone number"
                               @bind="NewParticipant.PhoneNumber"
                               @onclick:stopPropagation="true" />
                    </div>

                    <div class="join-actions" @onclick:stopPropagation="true">
                        <button type="button" class="join-cancel-btn"
                                @onclick="CloseJoinForm"
                                @onclick:stopPropagation="true">
                            Cancel
                        </button>
                        <button type="button" class="join-submit-btn"
                                @onclick="JoinDrive"
                                @onclick:stopPropagation="true">
                            Join Drive
                        </button>
                    </div>
                </div>
            </div>
        }
      

    </main>
    @if (ShowDiseaseModal)
    {
        <div class="join-modal-backdrop" @onclick="CloseDiseaseModal">
            <div class="join-modal-card modal-modern" style="max-width:600px; width:90%;" @onclick:stopPropagation="true">
                <div class="modal-header-modern">
                    <h3>🔬 Plant Disease Detection</h3>
                    <p class="join-modal-subtitle">Upload a leaf image to detect diseases using AI.</p>
                </div>

                <div style="padding: 20px 0;">
                    <InputFile OnChange="OnImageSelected" accept="image/*"
                               style="display:block; margin-bottom:16px;" />

                    @if (DiseaseImagePreview != null)
                    {
                        <img src="@DiseaseImagePreview"
                             style="width:100%; max-height:250px; object-fit:cover; border-radius:16px; margin-bottom:16px;" />
                    }

                    @if (IsDetecting)
                    {
                        <div style="text-align:center; padding:20px;">
                            <div class="spinner mb-3"></div>
                            <p>Analyzing image...</p>
                        </div>
                    }

                    @if (DiseaseResult != null)
                    {
                        @if (!string.IsNullOrEmpty(DiseaseResult.error))
                        {
                            <div style="background:#fff0f0; border-radius:16px; padding:20px; color:#c00;">
                                ⚠️ @DiseaseResult.error
                            </div>
                        }
                        else
                        {
                            <div style="background:#f0fdf4; border-radius:16px; padding:20px; margin-bottom:16px;">
                                <p><strong>🌿 Plant:</strong> @DiseaseResult.detected_plant</p>
                                <p><strong>🦠 Disease:</strong> @DiseaseResult.disease</p>
                                <p style="color:@(DiseaseResult.status == "Healthy" ? "#2e7d32" : "#c00"); font-weight:700;">
                                    @(DiseaseResult.status == "Healthy" ? "✅ Healthy" : "⚠️ " + DiseaseResult.status)
                                </p>
                                <p><strong>📊 Confidence:</strong> @((DiseaseResult.confidence * 100).ToString("F1"))%</p>
                            </div>

                            @if (DiseaseResult.top3?.Any() == true)
                            {
                                <div style="margin-bottom:16px;">
                                    <strong>Top Predictions:</strong>
                                    @foreach (var item in DiseaseResult.top3)
                                    {
                                        <div style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid #e5e7eb;">
                                            <span>@item.name</span>
                                            <span style="color:#2e7d32; font-weight:700;">@((item.confidence * 100).ToString("F1"))%</span>
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(DiseaseResult.ai_analysis))
                            {
                                <div style="background:#f8fafc; border-radius:16px; padding:16px; font-size:14px; line-height:1.8; max-height:200px; overflow-y:auto;">
                                    <strong>🧠 AI Analysis:</strong><br />
                                    @DiseaseResult.ai_analysis
                                </div>
                            }
                        }
                    }
                </div>

                <div class="join-actions">
                    <button type="button" class="join-cancel-btn" @onclick="CloseDiseaseModal">Close</button>
                    <button type="button" class="join-submit-btn"
                            @onclick="DetectDisease"
                            disabled="@(SelectedImageStream == null || IsDetecting)">
                        🔍 Detect Disease
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@if (isCartOpen)
{
    <div class="offcanvas-backdrop fade show" @onclick="CloseCartOffcanvas"></div>
}
@if (isCheckoutOpen)
{
    <div class="offcanvas-backdrop fade show" @onclick="CloseCheckoutOffcanvas"></div>
}

<!-- Loading State -->
@if (ProductList == null || ProductList.Count == 0)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 70vh;">
        <div class="text-center">
            <div class="spinner mb-3"></div>
            <p class="text-muted">Loading plants...</p>
        </div>
    </div>
}

else
{

    <!-- Enhanced Cart Offcanvas -->
    <div class="offcanvas offcanvas-end offcanvas-custom @(isCartOpen ? "show" : "")"
         tabindex="-1"
         id="cartOffcanvas"
         aria-labelledby="cartOffcanvasLabel"
         style="@(isCartOpen ? "visibility: visible;" : "")">
        <div class="offcanvas-header offcanvas-header-custom">
            <h5 class="offcanvas-title fw-bold" id="cartOffcanvasLabel">
                <i class="fas fa-shopping-cart me-2"></i>Your Shopping Cart
            </h5>
            <button type="button" class="btn-close btn-close-white" @onclick="CloseCartOffcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-4">

            <div class="mb-4 p-3 rounded-3" style="background-color: rgba(46, 125, 50, 0.1);">
                <h6 class="fw-bold mb-2 text-dark">Cart Summary</h6>
                <div class="d-flex justify-content-between">
                    <span>Total Amount:</span>
                    <span class="fw-bold text-success">Rs @TotalAmount</span>
                </div>
            </div>

            @if (cartItem?.Plants == null || !cartItem.Plants.Any())
            {
                <div class="text-center py-5">
                    <div class="empty-state-icon mb-3">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <h5 class="text-muted">Your cart is empty</h5>
                    <p class="text-muted small">Add some plants to get started!</p>
                </div>
            }
            else
            {
                <div class="cart-items">
                    @foreach (var product in cartItem.Plants)
                    {
                        <div class="cart-item">
                            <div class="card-body p-3">
                                <div class="row align-items-center">
                                    <div class="col-3">
                                        <img src="@product.ImageUrl" class="img-fluid rounded-3" style="height: 60px; width: 60px; object-fit: cover;" />
                                    </div>
                                    <div class="col-6">
                                        <h6 class="mb-1 fw-bold">@product.PlantName</h6>
                                        <small class="text-success fw-bold">Rs @product.Price</small>
                                    </div>
                                    <div class="col-3 text-end">
                                        <div class="quantity-controls">
                                            <button class="quantity-btn quantity-btn-decrease"
                                                    @onclick="() => DecreaseQuantity(!string.IsNullOrEmpty(product.ProID) ? product.ProID : product.Id)"
                                                    title="Remove one item">
                                                −
                                            </button>
                                            <div class="quantity-display">@product.Quantity</div>
                                            <button class="quantity-btn quantity-btn-increase"
                                                    @onclick="() => IncreaseQuantity(!string.IsNullOrEmpty(product.ProID) ? product.ProID : product.Id)"
                                                    title="Add one more">
                                                +
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (cartItem?.Plants == null || !cartItem.Plants.Any())
                {
                    // Cart is empty message
                }
                else
                {
                    <div class="cart-items">
                        <!-- ...cart items... -->
                    </div>
                    <!-- Enhanced Go to Checkout Button -->
                    <div class="mt-4">
                        <button class="btn btn-checkout text-white w-100 py-3" @onclick="GoToCheckout">
                            <i class="fas fa-arrow-right me-2"></i> Proceed to Checkout
                        </button>
                    </div>
                }
            }

        </div>
    </div>

    <!-- Backdrop for offcanvas -->
    @if (isCartOpen)
    {
        <div class="offcanvas-backdrop fade show" @onclick="CloseCartOffcanvas"></div>
    }

    <!-- Enhanced Checkout Offcanvas -->
    <div class="offcanvas offcanvas-end offcanvas-custom @(isCheckoutOpen ? "show" : "")"
         tabindex="-1"
         id="checkoutOffcanvas"
         aria-labelledby="checkoutOffcanvasLabel"
         style="@(isCheckoutOpen ? "visibility: visible;" : "")">
        <div class="offcanvas-header offcanvas-header-custom">
            <h5 class="offcanvas-title fw-bold" id="checkoutOffcanvasLabel">
                <i class="fas fa-credit-card me-2"></i>Secure Checkout
            </h5>
            <button type="button" class="btn-close btn-close-white" @onclick="CloseCheckoutOffcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-4">

            <!-- Enhanced Order Summary -->
            <div class="order-summary mb-4">
                <h6 class="fw-bold mb-3">Order Summary</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span>Items:</span>
                    <span class="fw-bold">@(cartItem?.Plants?.Count ?? 0)</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Total Amount:</span>
                    <span class="fw-bold fs-5">Rs @FinalAmount</span>
                </div>
            </div>

            <!-- Enhanced Checkout Form -->
            <div class="checkout-form">
                <form>
                    <!-- Personal Information -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="fas fa-user me-2"></i>Personal Information
                        </h6>
                        <div class="row g-3">
                            <div class="col-6">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="First Name*" @bind="checkoutForm.FirstName" required />
                            </div>
                            <div class="col-6">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="Last Name*" @bind="checkoutForm.LastName" required />
                            </div>
                            <div class="col-12">
                                <input type="email" class="form-control form-control-custom"
                                       placeholder="Email Address*" @bind="checkoutForm.Email" required />
                            </div>
                            <div class="col-12">
                                <input type="tel" class="form-control form-control-custom"
                                       placeholder="Phone Number*" @bind="checkoutForm.Phone" required />
                            </div>
                        </div>
                    </div>

                    <!-- Address Information -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="fas fa-home me-2"></i>Shipping Address
                        </h6>
                        <div class="row g-3">
                            <div class="col-12">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="Street Address*" @bind="checkoutForm.Address" required />
                            </div>
                            <div class="col-8">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="City*" @bind="checkoutForm.City" required />
                            </div>
                            <div class="col-4">
                                <input type="text" class="form-control form-control-custom"
                                       placeholder="Postal Code" @bind="checkoutForm.PostalCode" />
                            </div>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="fas fa-credit-card me-2"></i>Payment Method
                        </h6>
                        <div class="row g-2">
                            <div class="col-12">
                                <div class="form-check p-3 rounded-3" style="background-color: rgba(102, 126, 234, 0.1);">
                                    <input class="form-check-input" type="radio" name="paymentMethod" id="creditCard"
                                           value="Credit/Debit Card"
                                           @onchange="@(() => checkoutForm.PaymentMethod = "Credit/Debit Card")"
                                           checked="@(checkoutForm.PaymentMethod == "Credit/Debit Card")" />
                                    <label class="form-check-label fw-bold" for="creditCard">
                                        Credit Card / Debit Card (5% GST)
                                    </label>
                                </div>
