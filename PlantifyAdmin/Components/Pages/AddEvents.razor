@page "/admin/drives"
@layout AdminLayout
@using Entities
@inject IPlantationService PlantationService
@rendermode InteractiveServer

<PageTitle>Plantation Drives - Admin</PageTitle>

<div class="admin-drives">

    <!-- HEADER -->
    <div class="page-header">
        <div class="header-left">
            <h1>🌱 Plantation Drives</h1>
            <p>Manage and monitor all plantation drive events</p>
        </div>
        <button class="add-btn" @onclick="ShowAddForm">
            ➕ Add New Drive
        </button>
    </div>

    <!-- STATS ROW -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon">🌱</div>
            <div class="stat-info">
                <h3>@(plantations?.Count ?? 0)</h3>
                <p>Total Drives</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">👥</div>
            <div class="stat-info">
                <h3>@(plantations?.Sum(p => p.Participants?.Count ?? 0) ?? 0)</h3>
                <p>Total Participants</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🌳</div>
            <div class="stat-info">
                <h3>@(plantations?.Sum(p => p.TotalSaplings) ?? 0)</h3>
                <p>Total Saplings</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📅</div>
            <div class="stat-info">
                <h3>@(plantations?.Count(p => p.Date >= DateTime.Today) ?? 0)</h3>
                <p>Upcoming Drives</p>
            </div>
        </div>
    </div>

    <!-- TABLE SECTION -->
    <div class="table-card">
        <div class="table-header">
            <h2>All Drives</h2>
            <span class="drive-count">@(plantations?.Count ?? 0) drives</span>
        </div>

        @if (plantations == null)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Loading drives...</p>
            </div>
        }
        else if (!plantations.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🌱</div>
                <h3>No plantation drives yet</h3>
                <p>Click "Add New Drive" to create your first plantation drive</p>
                <button class="add-btn" @onclick="ShowAddForm">➕ Add New Drive</button>
            </div>
        }
        else
        {
            <div class="drives-table-wrap">
                <table class="drives-table">
                    <thead>
                        <tr>
                            <th>Drive</th>
                            <th>Location</th>
                            <th>Date</th>
                            <th>Organizer</th>
                            <th>Saplings</th>
                            <th>Participants</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in plantations)
                        {
                            <tr>
                                <td>
                                    <div class="drive-name-cell">
                                        <div class="drive-icon">🌱</div>
                                        <span class="drive-name">@p.Title</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="location-cell">📍 @p.Location</span>
                                </td>
                                <td>
                                    <span class="date-cell">📅 @p.Date.ToString("MMM dd, yyyy")</span>
                                </td>
                                <td>
                                    <span class="organizer-cell">🏢 @p.OrganizedBy</span>
                                </td>
                                <td>
                                    <span class="saplings-badge">🌳 @p.TotalSaplings</span>
                                </td>
                                <td>
                                    <span class="participants-badge">👥 @(p.Participants?.Count ?? 0)</span>
                                </td>
                                <td>
                                    @if (p.Date >= DateTime.Today)
                                    {
                                        <span class="status-badge status-upcoming">Upcoming</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-completed">Completed</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <button class="edit-btn" @onclick="() => Edit(p)">✏️ Edit</button>
                                        <button class="delete-btn" @onclick="() => Delete(p.Id!)">🗑️ Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- MODAL -->
@if (showForm)
{
    <div class="modal-backdrop" @onclick="Cancel">
        <div class="modal-card" @onclick:stopPropagation="true">

            <div class="modal-header">
                <div>
                    <h2>@(string.IsNullOrEmpty(editing.Id) ? "➕ Add New Drive" : "✏️ Edit Drive")</h2>
                    <p>@(string.IsNullOrEmpty(editing.Id) ? "Create a new plantation drive event" : "Update drive information")</p>
                </div>
                <button class="close-btn" @onclick="Cancel">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-alert">⚠️ @errorMessage</div>
            }

            <div class="modal-body">
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>Drive Title *</label>
                        <input class="form-input" placeholder="e.g. Green City Drive" @bind="editing.Title" />
                    </div>

                    <div class="form-group full-width">
                        <label>Location *</label>
                        <input class="form-input" placeholder="e.g. Central Park, Lahore" @bind="editing.Location" />
                    </div>

                    <div class="form-group">
                        <label>Latitude</label>
                        <input class="form-input" type="number" step="0.0001"
                               placeholder="e.g. 33.6844"
                               @bind="editing.Latitude" />
                        <span class="form-hint">Get from <a href="https://latlong.net" target="_blank">latlong.net</a></span>
                    </div>

                    <div class="form-group">
                        <label>Longitude</label>
                        <input class="form-input" type="number" step="0.0001"
                               placeholder="e.g. 73.0479"
                               @bind="editing.Longitude" />
                    </div>

                    <div class="form-group">
                        <label>Date *</label>
                        <input class="form-input" type="date"
                               @bind="editing.Date"
                               @bind:format="yyyy-MM-dd" />
                    </div>

                    <div class="form-group">
                        <label>Total Saplings *</label>
                        <input class="form-input" type="number" min="1"
                               placeholder="e.g. 500"
                               @bind="editing.TotalSaplings" />
                    </div>

                    <div class="form-group full-width">
                        <label>Organized By *</label>
                        <input class="form-input" placeholder="e.g. City Council" @bind="editing.OrganizedBy" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="cancel-btn" @onclick="Cancel">Cancel</button>
                <button class="save-btn" @onclick="Save">💾 Save Drive</button>
            </div>

        </div>
    </div>
}

<style>
    .admin-drives {
        padding: 30px;
        background: #f4f7f3;
        min-height: 100vh;
    }

    /* HEADER */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .header-left h1 {
        font-size: 36px;
        font-weight: 900;
        color: #1b5e20;
        margin-bottom: 6px;
    }

    .header-left p {
        color: #6b7280;
        margin: 0;
        font-size: 15px;
    }

    .add-btn {
        background: linear-gradient(135deg, #43a047, #2e7d32);
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .add-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(67,160,71,0.35);
        }

    /* STATS */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.04);
        transition: 0.3s;
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(0,0,0,0.08);
        }

    .stat-icon {
        font-size: 36px;
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-info h3 {
        font-size: 30px;
        font-weight: 900;
        color: #1b5e20;
        margin: 0 0 4px 0;
    }

    .stat-info p {
        color: #6b7280;
        font-size: 13px;
        margin: 0;
        font-weight: 600;
    }

    /* TABLE CARD */
    .table-card {
        background: white;
        border-radius: 24px;
        padding: 28px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.04);
    }

    .table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

        .table-header h2 {
            font-size: 22px;
            font-weight: 800;
            color: #1b5e20;
            margin: 0;
        }

    .drive-count {
        background: #f0fdf4;
        color: #2e7d32;
        padding: 6px 16px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    /* TABLE */
    .drives-table-wrap {
        overflow-x: auto;
        border-radius: 16px;
        border: 1px solid #f0fdf4;
    }

    .drives-table {
        width: 100%;
        border-collapse: collapse;
    }

        .drives-table thead tr {
            background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        }

        .drives-table th {
            padding: 14px 18px;
            text-align: left;
            font-size: 13px;
            font-weight: 700;
            color: #1b5e20;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        .drives-table td {
            padding: 16px 18px;
            border-bottom: 1px solid #f9fafb;
            vertical-align: middle;
        }

        .drives-table tbody tr:hover {
            background: #f9fafb;
        }

        .drives-table tbody tr:last-child td {
            border-bottom: none;
        }

    /* CELLS */
    .drive-name-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .drive-icon {
        font-size: 20px;
        width: 40px;
        height: 40px;
        background: #f0fdf4;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .drive-name {
        font-weight: 700;
        color: #111827;
        font-size: 15px;
    }

    .location-cell, .date-cell, .organizer-cell {
        color: #6b7280;
        font-size: 14px;
        font-weight: 600;
    }

    .saplings-badge {
        background: #f0fdf4;
        color: #2e7d32;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
    }

    .participants-badge {
        background: #eff6ff;
        color: #1d4ed8;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-badge {
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-upcoming {
        background: #f0fdf4;
        color: #2e7d32;
        border: 1px solid #86efac;
    }

    .status-completed {
        background: #f9fafb;
        color: #6b7280;
        border: 1px solid #e5e7eb;
    }

    /* ACTION BUTTONS */
    .action-btns {
        display: flex;
        gap: 8px;
    }

    .edit-btn {
        background: #eff6ff;
        color: #1d4ed8;
        border: none;
        padding: 8px 14px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.2s;
        white-space: nowrap;
    }

        .edit-btn:hover {
            background: #dbeafe;
            transform: translateY(-1px);
        }

    .delete-btn {
        background: #fff0f0;
        color: #dc2626;
        border: none;
        padding: 8px 14px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: 0.2s;
        white-space: nowrap;
    }

        .delete-btn:hover {
            background: #fee2e2;
            transform: translateY(-1px);
        }

    /* LOADING & EMPTY */
    .loading-state, .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #6b7280;
    }

    .empty-icon {
        font-size: 72px;
        margin-bottom: 16px;
    }

    .empty-state h3 {
        font-size: 22px;
        font-weight: 700;
        color: #374151;
        margin-bottom: 8px;
    }

    .empty-state p {
        margin-bottom: 24px;
    }

    .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #dcfce7;
        border-top-color: #2e7d32;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 16px auto;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* MODAL */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(8px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        padding: 20px;
    }

    .modal-card {
        background: white;
        border-radius: 28px;
        width: 100%;
        max-width: 620px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.2);
        animation: slideUp 0.3s ease;
        max-height: 90vh;
        overflow-y: auto;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 28px 32px 0 32px;
    }

        .modal-header h2 {
            font-size: 24px;
            font-weight: 800;
            color: #1b5e20;
            margin-bottom: 6px;
        }

        .modal-header p {
            color: #6b7280;
            margin: 0;
            font-size: 14px;
        }

    .close-btn {
        background: #f3f4f6;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
        flex-shrink: 0;
    }

        .close-btn:hover {
            background: #e5e7eb;
        }

    .error-alert {
        margin: 16px 32px 0 32px;
        background: #fff0f0;
        border: 1px solid #fca5a5;
        color: #dc2626;
        padding: 12px 16px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 14px;
    }

    .modal-body {
        padding: 24px 32px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .full-width {
        grid-column: 1 / -1;
    }

    .form-group label {
        font-size: 13px;
        font-weight: 700;
        color: #374151;
    }

    .form-input {
        border: 1.5px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 15px;
        outline: none;
        transition: 0.2s;
        color: #111827;
        width: 100%;
        box-sizing: border-box;
    }

        .form-input:focus {
            border-color: #2e7d32;
            box-shadow: 0 0 0 3px rgba(46,125,50,0.1);
        }

    .form-hint {
        font-size: 12px;
        color: #9ca3af;
    }

        .form-hint a {
            color: #2e7d32;
            font-weight: 600;
        }

    .modal-footer {
        display: flex;
        gap: 14px;
        padding: 0 32px 28px 32px;
    }

    .cancel-btn {
        flex: 1;
        background: #f9fafb;
        border: 1.5px solid #e5e7eb;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        color: #374151;
        transition: 0.2s;
    }

        .cancel-btn:hover {
            background: #f3f4f6;
        }

    .save-btn {
        flex: 2;
        background: linear-gradient(135deg, #43a047, #2e7d32);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .save-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(67,160,71,0.3);
        }

    @@media (max-width: 768px) {
        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .full-width {
            grid-column: 1;
        }
    }
</style>

@code {
    private List<Plantation>? plantations;
    private Plantation editing = new Plantation();
    private bool showForm = false;
    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        plantations = PlantationService.GetAll();
    }

    private void ShowAddForm()
    {
        editing = new Plantation { Date = DateTime.Today };
        errorMessage = string.Empty;
        showForm = true;
    }

    private void Edit(Plantation p)
    {
        editing = new Plantation
        {
            Id = p.Id,
            Title = p.Title,
            Location = p.Location,
            Date = p.Date == default ? DateTime.Today : p.Date,
            OrganizedBy = p.OrganizedBy,
            TotalSaplings = p.TotalSaplings,
            Participants = p.Participants,
            Latitude = p.Latitude,
            Longitude = p.Longitude
        };
        errorMessage = string.Empty;
        showForm = true;
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(editing.Title) ||
            string.IsNullOrWhiteSpace(editing.Location) ||
            string.IsNullOrWhiteSpace(editing.OrganizedBy) ||
            editing.TotalSaplings <= 0 ||
            editing.Date == default)
        {
            errorMessage = "Please fill in all required fields.";
            return;
        }

        if (string.IsNullOrEmpty(editing.Id))
            PlantationService.Add(editing);
        else
            PlantationService.Update(editing);

        showForm = false;
        errorMessage = string.Empty;
        LoadData();
    }

    private void Delete(string id)
    {
        PlantationService.Delete(id);
        LoadData();
    }

    private void Cancel()
    {
        showForm = false;
        errorMessage = string.Empty;
    }
}