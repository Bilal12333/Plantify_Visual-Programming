    }

    .filter-chips {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .chip {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        padding: 10px 18px;
        border-radius: 999px;
        font-weight: 600;
