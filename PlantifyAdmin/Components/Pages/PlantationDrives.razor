        font-size: 24px;
        font-weight: 700;
        color: #374151;
        margin-bottom: 10px;
    }

    .spinner-green {
        width: 50px;
        height: 50px;
        border: 4px solid #dcfce7;
        border-top-color: #2e7d32;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 20px auto;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(8px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        padding: 20px;
    }

    /* MAP MODAL */
    .map-modal {
        background: white;
        border-radius: 28px;
        padding: 36px;
        width: 100%;
        max-width: 780px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.2);
        animation: slideUp 0.3s ease;
        max-height: 90vh;
        overflow-y: auto;
    }

    .map-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
    }

        .map-modal-header h2 {
            font-size: 24px;
            font-weight: 800;
            color: #1b5e20;
            margin-bottom: 4px;
        }

        .map-modal-header p {
            color: #6b7280;
            margin: 0;
        }

    .close-btn {
        background: #f3f4f6;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
        flex-shrink: 0;
    }

        .close-btn:hover {
            background: #e5e7eb;
        }

    .map-info-strip {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 20px;
        padding: 16px;
        background: #f0fdf4;
        border-radius: 16px;
    }

    .map-info-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        background: white;
        padding: 8px 14px;
