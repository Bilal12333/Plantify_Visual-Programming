@code {
    private bool ShowMapModal = false;
    private Plantation? SelectedDrive;
    private List<Plantation>? PlantationDrivesList;
    private bool ShowJoinPopup;
    private string SelectedDriveId = string.Empty;
    private string JoinError = string.Empty;
    private ParticipantInput NewParticipant = new();
    private string SearchQuery = "";
    private string SortBy = "date";

    protected override void OnInitialized()
    {
        PlantationDrivesList = PlantationService.GetAll();
    }

    private async Task OpenMapModal(Plantation drive)
    {
        SelectedDrive = drive;
        ShowMapModal = true;
        StateHasChanged();

        await Task.Delay(300);
        await JSRuntime.InvokeVoidAsync("plantifyMaps.initMap",
            "leaflet-map",
            drive.Latitude,
            drive.Longitude,
            drive.Title);
    }

    private async Task CloseMapModal()
    {
        ShowMapModal = false;
        await JSRuntime.InvokeVoidAsync("plantifyMaps.destroyMap");
        StateHasChanged();
    }

    private async Task GetDirections()
    {
        if (SelectedDrive == null) return;
        await JSRuntime.InvokeVoidAsync("plantifyMaps.getDirections",
            SelectedDrive.Latitude,
            SelectedDrive.Longitude);
    }

    private IEnumerable<Plantation> FilteredDrives
    {
        get
        {
            var drives = PlantationDrivesList ?? new List<Plantation>();

            if (!string.IsNullOrWhiteSpace(SearchQuery))
                drives = drives.Where(d =>
                    (d.Title?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (d.Location?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
                    .ToList();

            return SortBy switch
            {
                "saplings" => drives.OrderByDescending(d => d.TotalSaplings),
                "participants" => drives.OrderByDescending(d => d.Participants?.Count ?? 0),
                _ => drives.OrderBy(d => d.Date)
            };
        }
    }

    private void ShowJoinForm(string driveId)
    {
        SelectedDriveId = driveId;
        JoinError = string.Empty;
        NewParticipant = new ParticipantInput();
        ShowJoinPopup = true;
    }

    private void CloseJoinForm()
    {
        ShowJoinPopup = false;
        SelectedDriveId = string.Empty;
        JoinError = string.Empty;
        NewParticipant = new ParticipantInput();
    }

    private async Task JoinDrive()
    {
        if (string.IsNullOrWhiteSpace(NewParticipant.FirstName) ||
            string.IsNullOrWhiteSpace(NewParticipant.LastName) ||
            string.IsNullOrWhiteSpace(NewParticipant.Email) ||
            string.IsNullOrWhiteSpace(NewParticipant.PhoneNumber))
        {
            JoinError = "All fields are required.";
            return;
        }

        var drive = PlantationDrivesList?.FirstOrDefault(x => x.Id == SelectedDriveId);
        if (drive is null) { JoinError = "Drive not found."; return; }

        // Snapshots
        var participantSnapshot = new ParticipantInput
        {
            FirstName = NewParticipant.FirstName,
            LastName = NewParticipant.LastName,
            Email = NewParticipant.Email,
            PhoneNumber = NewParticipant.PhoneNumber
        };

        var driveSnapshot = new Plantation
        {
            Id = drive.Id,
            Title = drive.Title,
            Location = drive.Location,
            Date = drive.Date,
            OrganizedBy = drive.OrganizedBy,
            TotalSaplings = drive.TotalSaplings
        };

        // ✅ Save as structured document in Participants collection
        var driveParticipant = new DriveParticipant
        {
            DriveId = drive.Id!,
            DriveTitle = drive.Title ?? "",
            FirstName = participantSnapshot.FirstName,
            LastName = participantSnapshot.LastName,
            Email = participantSnapshot.Email,
            PhoneNumber = participantSnapshot.PhoneNumber,
            JoinedAt = DateTime.UtcNow
        };

        await ParticipantService.SaveAsync(driveParticipant);

        // Still update participant count on the drive document
        drive.Participants ??= new List<string>();
        drive.Participants.Add(participantSnapshot.Email); // just store email as reference
        PlantationService.Update(drive);
        PlantationDrivesList = PlantationService.GetAll();
        CloseJoinForm();
        StateHasChanged();

        // Send confirmation email
        try
        {
            await EmailService.SendDriveConfirmationAsync(driveSnapshot, participantSnapshot);
            ToastService.Show($"Successfully joined {driveSnapshot.Title}! Confirmation sent to {participantSnapshot.Email} 🌱", "success");
        }
        catch (Exception ex)
        {
            Console.WriteLine("DRIVE EMAIL ERROR: " + ex.ToString());
            ToastService.Show($"Joined {driveSnapshot.Title}! But email failed: " + ex.Message, "warning");
        }
    }

   
}