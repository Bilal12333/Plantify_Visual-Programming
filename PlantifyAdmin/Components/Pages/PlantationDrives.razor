            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

    .drive-card-top {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .drive-card-icon {
        font-size: 32px;
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
