        background: linear-gradient(135deg, #43a047, #2e7d32) !important;
        color: white !important;
        border-color: transparent !important;
    }

    .drives-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
