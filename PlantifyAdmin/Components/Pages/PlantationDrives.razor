@page "/plantation-drives"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject IPlantationService PlantationService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer
@layout UserMainLayout
@inject EmailService EmailService
@inject ToastService ToastService
@using PlantifyAdmin.Services
@using Entities
@inject IParticipantService ParticipantService
@using DAL

<PageTitle>Plantation Drives</PageTitle>

<div class="drives-page">

    <!-- SIDEBAR -->
    <aside class="drives-sidebar">
        <div class="sidebar-section">
            <p class="sidebar-title">NAVIGATION</p>
            <NavLink class="sidebar-link" href="/dashboard">
                <span class="sidebar-icon">🏠</span> Dashboard
            </NavLink>
            <NavLink class="sidebar-link" href="/plantation-drives" Match="NavLinkMatch.All">
                <span class="sidebar-icon">🌱</span> Plantation Drives
            </NavLink>
            <NavLink class="sidebar-link" href="/plant-ai">
                <span class="sidebar-icon">🤖</span> Plant AI Assistant
            </NavLink>
            <NavLink class="sidebar-link" href="/disease-detection">
                <span class="sidebar-icon">🔬</span> Disease Detection
            </NavLink>
        </div>

        <div class="sidebar-section">
            <p class="sidebar-title">STATS</p>
            <div class="stats-card">
                <div class="stat-item">
                    <span class="stat-icon">🌱</span>
                    <div>
                        <p class="stat-number">@(PlantationDrivesList?.Count ?? 0)</p>
                        <p class="stat-label">Total Drives</p>
                    </div>
                </div>
                <div class="stat-item">
                    <span class="stat-icon">👥</span>
                    <div>
                        <p class="stat-number">@(PlantationDrivesList?.Sum(d => d.Participants?.Count ?? 0) ?? 0)</p>
                        <p class="stat-label">Participants</p>
                    </div>
                </div>
                <div class="stat-item">
                    <span class="stat-icon">🌳</span>
                    <div>
                        <p class="stat-number">@(PlantationDrivesList?.Sum(d => d.TotalSaplings) ?? 0)</p>
                        <p class="stat-label">Total Saplings</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="sidebar-section">
            <p class="sidebar-title">UPCOMING</p>
            @if (PlantationDrivesList?.Any() == true)
            {
                <div class="upcoming-list">
                    @foreach (var drive in PlantationDrivesList.Take(3))
                    {
                        <div class="upcoming-item">
                            <div class="upcoming-dot"></div>
                            <div>
                                <p class="upcoming-title">@drive.Title</p>
                                <p class="upcoming-date">@drive.Date.ToString("MMM dd, yyyy")</p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </aside>

    <!-- MAIN -->
    <main class="drives-main">

        <!-- HERO -->
        <div class="drives-hero">
            <div class="hero-left">
                <span class="hero-badge">🌿 Community Initiative</span>
                <h1>Plantation Drives</h1>
                <p>Join hands with your community to plant trees and create a greener tomorrow.</p>
                <div class="hero-stats-row">
                    <div class="hero-stat">
                        <h3>@(PlantationDrivesList?.Count ?? 0)</h3>
                        <p>Active Drives</p>
                    </div>
                    <div class="hero-stat">
                        <h3>@(PlantationDrivesList?.Sum(d => d.Participants?.Count ?? 0) ?? 0)</h3>
                        <p>Participants</p>
                    </div>
                    <div class="hero-stat">
                        <h3>@(PlantationDrivesList?.Sum(d => d.TotalSaplings) ?? 0)+</h3>
                        <p>Trees Planned</p>
                    </div>
                </div>
            </div>
            <div class="hero-illustration">
                <svg viewBox="0 0 300 200" xmlns="http://www.w3.org/2000/svg">
                    <ellipse cx="150" cy="185" rx="150" ry="18" fill="rgba(255,255,255,0.15)" />
                    <rect x="80" y="90" width="10" height="95" rx="5" fill="rgba(255,255,255,0.6)" />
                    <ellipse cx="85" cy="80" rx="28" ry="34" fill="rgba(255,255,255,0.4)" />
                    <ellipse cx="70" cy="95" rx="18" ry="22" fill="rgba(255,255,255,0.3)" />
                    <rect x="145" y="60" width="14" height="125" rx="7" fill="rgba(255,255,255,0.6)" />
                    <ellipse cx="152" cy="45" rx="36" ry="42" fill="rgba(255,255,255,0.4)" />
                    <ellipse cx="135" cy="68" rx="22" ry="26" fill="rgba(255,255,255,0.3)" />
                    <rect x="220" y="80" width="10" height="105" rx="5" fill="rgba(255,255,255,0.6)" />
                    <ellipse cx="225" cy="70" rx="24" ry="30" fill="rgba(255,255,255,0.4)" />
                </svg>
            </div>
        </div>

        <!-- SEARCH & FILTER BAR -->
        <div class="filter-bar">
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text"
                       placeholder="Search drives by title or location..."
                       @bind="SearchQuery"
                       @bind:event="oninput"
                       class="search-input" />
            </div>
            <div class="filter-chips">
                <button class="chip @(SortBy == "date" ? "chip-active" : "")"
                        @onclick='() => SortBy = "date"'>
                    📅 By Date
                </button>
                <button class="chip @(SortBy == "saplings" ? "chip-active" : "")"
                        @onclick='() => SortBy = "saplings"'>
                    🌳 By Saplings
                </button>
                <button class="chip @(SortBy == "participants" ? "chip-active" : "")"
                        @onclick='() => SortBy = "participants"'>
                    👥 By Participants
                </button>
            </div>
        </div>

        <!-- DRIVES GRID -->
        @if (PlantationDrivesList == null)
        {
            <div class="loading-state">
                <div class="spinner-green"></div>
                <p>Loading plantation drives...</p>
            </div>
        }
        else if (!FilteredDrives.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🌱</div>
                <h3>No drives found</h3>
                <p>Try adjusting your search or check back later for new drives.</p>
            </div>
        }
        else
        {
            <div class="drives-grid">
                @foreach (var drive in FilteredDrives)
                {
                    <article class="drive-card" @onclick="() => OpenMapModal(drive)" style="cursor:pointer;">
                        <div class="drive-card-top">
                            <div class="drive-card-icon">🌱</div>
                            <div class="drive-meta">
                                <span class="drive-organizer">by @drive.OrganizedBy</span>
                                <span class="drive-date-badge">📅 @drive.Date.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                        <h3 class="drive-title">@drive.Title</h3>
                        <div class="drive-info-grid">
                            <div class="drive-info-item">
                                <span class="info-icon">📍</span>
                                <div>
                                    <p class="info-label">Location</p>
                                    <p class="info-value">@drive.Location</p>
                                </div>
                            </div>
                            <div class="drive-info-item">
                                <span class="info-icon">🌳</span>
                                <div>
                                    <p class="info-label">Saplings Goal</p>
                                    <p class="info-value">@drive.TotalSaplings trees</p>
                                </div>
                            </div>
                        </div>
                        <div class="progress-section">
                            <div class="progress-header">
                                <span>Participants</span>
                                <span class="progress-count">👥 @(drive.Participants?.Count ?? 0) joined</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill"
                                     style="width:@(Math.Min(((drive.Participants?.Count ?? 0) * 10), 100))%">
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <span class="view-details">👁 Click to view details & map</span>
                        </div>
                    </article>
                }
            </div>
        }

    </main>
</div>

<!-- ✅ MAP MODAL -->
@if (ShowMapModal && SelectedDrive != null)
{
    <div class="modal-backdrop" @onclick="CloseMapModal">
        <div class="map-modal" @onclick:stopPropagation="true">

            <div class="map-modal-header">
                <div>
                    <h2>📍 @SelectedDrive.Title</h2>
                    <p>@SelectedDrive.Location</p>
                </div>
                <button class="close-btn" @onclick="CloseMapModal">✕</button>
            </div>

            <div class="map-info-strip">
                <div class="map-info-item">
                    <span>📅</span>
                    <span>@SelectedDrive.Date.ToString("MMMM dd, yyyy")</span>
                </div>
                <div class="map-info-item">
                    <span>👥</span>
                    <span>@(SelectedDrive.Participants?.Count ?? 0) participants</span>
                </div>
                <div class="map-info-item">
                    <span>🌳</span>
                    <span>@SelectedDrive.TotalSaplings saplings</span>
                </div>
                <div class="map-info-item">
                    <span>🏢</span>
                    <span>by @SelectedDrive.OrganizedBy</span>
                </div>
            </div>

            <div id="leaflet-map" style="height:380px; border-radius:16px; overflow:hidden; margin-bottom:20px;"></div>

            <div class="map-actions">
                <button class="directions-btn" @onclick="GetDirections">
                    🧭 Get Directions from My Location
                </button>
                <button class="join-btn" @onclick="() => { _ = CloseMapModal(); ShowJoinForm(SelectedDrive.Id!); }">
                    🤝 Join This Drive
                </button>
            </div>

        </div>
    </div>
}

<!-- ✅ JOIN MODAL -->
@if (ShowJoinPopup)
{
    <div class="modal-backdrop" @onclick="CloseJoinForm">
        <div class="join-modal" @onclick:stopPropagation="true">

            <div class="join-modal-header">
                <div class="join-modal-icon">🌱</div>
                <h2>Join Plantation Drive</h2>
                <p>Fill in your details to participate</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(JoinError))
            {
                <div class="join-error">⚠️ @JoinError</div>
            }

            <div class="join-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>First Name *</label>
                        <input class="form-input" placeholder="John" @bind="NewParticipant.FirstName" />
                    </div>
                    <div class="form-group">
                        <label>Last Name *</label>
                        <input class="form-input" placeholder="Doe" @bind="NewParticipant.LastName" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Email Address *</label>
                    <input class="form-input" type="email" placeholder="john@example.com" @bind="NewParticipant.Email" />
                </div>
                <div class="form-group">
                    <label>Phone Number *</label>
                    <input class="form-input" type="tel" placeholder="+92 300 0000000" @bind="NewParticipant.PhoneNumber" />
                </div>
            </div>

            <div class="join-modal-actions">
                <button class="cancel-btn" @onclick="CloseJoinForm">Cancel</button>
                <button class="submit-btn" @onclick="JoinDrive">🤝 Join Drive</button>
            </div>

        </div>
    </div>
}

