    }

    .info-label {
        font-size: 11px;
        color: #9ca3af;
        font-weight: 600;
        margin: 0 0 3px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-value {
        font-size: 14px;
        font-weight: 700;
        color: #374151;
        margin: 0;
