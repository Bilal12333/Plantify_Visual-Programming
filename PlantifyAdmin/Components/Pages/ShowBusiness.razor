@page "/business/products"
@layout BusinessLayout
@rendermode InteractiveServer

@inject IBusinessService BusinessService
@inject IPlantService PlantService
@inject IWebHostEnvironment WebHostEnvironment

@using Entities
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Hosting

<PageTitle>Manage Products - Plantify</PageTitle>

<div class="products-page">

    <!-- HEADER -->
    <div class="page-header">
        <div class="header-left">
            <h1>📋 Manage Products</h1>
            <p>Add and manage products for your registered businesses</p>
        </div>
        <a class="register-btn" href="/business/register">
            🏪 Business Registration
        </a>
    </div>

    <!-- STATS -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon">🏢</div>
            <div class="stat-info">
                <h3>@(businesses?.Count ?? 0)</h3>
                <p>Businesses</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📦</div>
            <div class="stat-info">
                <h3>@(businesses?.Sum(b => b.Products?.Count ?? 0) ?? 0)</h3>
                <p>Total Products</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🌿</div>
            <div class="stat-info">
                <h3>@(categoryMap.Count)</h3>
                <p>Categories</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div class="stat-info">
                <h3>Active</h3>
                <p>Store Status</p>
            </div>
        </div>
    </div>

    <!-- BUSINESSES -->
    @if (businesses == null)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading businesses...</p>
        </div>
    }
    else if (!businesses.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🏢</div>
            <h3>No businesses registered yet</h3>
            <p>Register your business first to start adding products</p>
            <a class="register-btn" href="/business/register">🏪 Register Business</a>
        </div>
    }
    else
    {
        <div class="businesses-grid">
            @foreach (var biz in businesses)
            {
                <div class="business-card">

                    <!-- BUSINESS IMAGE -->
                    <div class="business-image-wrap">
                        @if (!string.IsNullOrEmpty(biz.Image))
                        {
                            <img src="@biz.Image" class="business-image" alt="@biz.ShopName" />
                        }
                        else
                        {
                            <div class="business-image-fallback">🏪</div>
                        }
                        <div class="business-badge">Active</div>
                    </div>

                    <!-- BUSINESS INFO -->
                    <div class="business-info">
                        <h3 class="business-name">@biz.ShopName</h3>
                        <div class="business-meta">
                            <span>📞 @biz.Phone</span>
                            <span>📍 @biz.Location</span>
                        </div>
                    </div>

                    <!-- ADD PRODUCT BUTTONS -->
                    <div class="product-actions">
                        <p class="actions-label">Add Products</p>
                        <div class="category-btns">
                            @foreach (var cat in categoryMap.Keys)
                            {
                                var emoji = cat switch
                                {
                                    "Plants" => "🌿",
                                    "Tools" => "🔧",
                                    "Fertilizers" => "🌱",
                                    "Medicinal Kits" => "💊",
                                    _ => "📦"
                                };
                                <button class="cat-btn cat-btn-@cat.Replace(" ", "").ToLower()"
                                        @onclick='() => OpenAddProductModal(biz.Id!, null, cat)'>
                                    @emoji @cat
                                </button>
                            }
                        </div>
                    </div>

                </div>
            }
        </div>
    }
</div>

<!-- PRODUCT MODAL -->
@if (isAddProductModalOpen)
{
    <div class="modal-backdrop" @onclick="CloseAddProductModal">
        <div class="modal-card" @onclick:stopPropagation="true">

            <div class="modal-header">
                <div>
                    <h2>@(isEditMode ? "✏️ Edit Product" : $"➕ Add {selectedCategory}")</h2>
                    <p>@(isEditMode ? "Update product information" : $"Add a new {selectedCategory.ToLower()} product")</p>
                </div>
                <button class="close-btn" @onclick="CloseAddProductModal">✕</button>
            </div>

            <EditForm Model="newProduct" OnValidSubmit="SaveProduct">
                <DataAnnotationsValidator />

                <div class="modal-body">
                    <div class="form-grid">

                        <div class="form-group full-width">
                            <label>Product Name *</label>
                            <InputText class="form-input" placeholder="e.g. Rose Plant" @bind-Value="newProduct.PlantName" />
                        </div>

                        <div class="form-group full-width">
                            <label>Description</label>
                            <InputText class="form-input" placeholder="Brief description of the product" @bind-Value="newProduct.Description" />
                        </div>

                        <div class="form-group">
                            <label>Subcategory *</label>
                            <InputSelect class="form-input" @bind-Value="selectedSubCategory">
                                <option value="">-- Select Subcategory --</option>
                                @foreach (var sub in subCategories)
                                {
                                    <option value="@sub">@sub</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label>Price (Rs) *</label>
                            <InputNumber class="form-input" placeholder="e.g. 500" @bind-Value="newProduct.Price" />
                        </div>

                        <div class="form-group">
                            <label>Quantity *</label>
                            <InputNumber class="form-input" placeholder="e.g. 50" @bind-Value="newProduct.Quantity" />
                        </div>

                        <div class="form-group">
                            <label>Product Image</label>
                            <InputFile OnChange="HandleFileUpload" class="form-input-file" />
                            @if (!string.IsNullOrEmpty(newProduct.ImageUrl))
                            {
                                <img src="@newProduct.ImageUrl"
                                     style="height:100px; border-radius:12px; margin-top:10px; object-fit:cover;" />
                            }
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="cancel-btn" @onclick="CloseAddProductModal">Cancel</button>
                    <button type="submit" class="save-btn">
                        @(isEditMode ? "💾 Update Product" : "💾 Save Product")
                    </button>
                </div>

            </EditForm>
        </div>
    </div>
}

<style>
    .products-page {
        padding: 30px;
        background: #f4f7f3;
        min-height: 100vh;
    }

    /* HEADER */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .header-left h1 {
        font-size: 36px;
        font-weight: 900;
        color: #1b5e20;
        margin-bottom: 6px;
    }

    .header-left p {
        color: #6b7280;
        margin: 0;
        font-size: 15px;
    }

    .register-btn {
        background: linear-gradient(135deg, #43a047, #2e7d32);
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .register-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(67,160,71,0.35);
        color: white;
    }

    /* STATS */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.04);
        transition: 0.3s;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(0,0,0,0.08);
    }

    .stat-icon {
        font-size: 36px;
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-info h3 {
        font-size: 28px;
        font-weight: 900;
        color: #1b5e20;
        margin: 0 0 4px 0;
    }

    .stat-info p {
        color: #6b7280;
        font-size: 13px;
        margin: 0;
        font-weight: 600;
    }

    /* BUSINESSES GRID */
    .businesses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 24px;
    }

    .business-card {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
    }

    .business-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    /* BUSINESS IMAGE */
    .business-image-wrap {
        height: 200px;
        position: relative;
        overflow: hidden;
    }

    .business-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .business-card:hover .business-image {
        transform: scale(1.05);
    }

    .business-image-fallback {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 80px;
    }

    .business-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        background: linear-gradient(135deg, #43a047, #2e7d32);
        color: white;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    /* BUSINESS INFO */
    .business-info {
        padding: 20px 24px 16px 24px;
        border-bottom: 1px solid #f0fdf4;
    }

    .business-name {
        font-size: 22px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 10px;
    }

    .business-meta {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .business-meta span {
        font-size: 14px;
        color: #6b7280;
        font-weight: 600;
    }

    /* PRODUCT ACTIONS */
    .product-actions {
        padding: 20px 24px;
    }

    .actions-label {
        font-size: 13px;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 12px;
    }

    .category-btns {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .cat-btn {
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .cat-btn:hover {
        transform: translateY(-2px);
    }

    .cat-btn-plants {
        background: #f0fdf4;
        color: #2e7d32;
        border: 1px solid #86efac;
    }

    .cat-btn-plants:hover { background: #dcfce7; }

    .cat-btn-tools {
        background: #f0f9ff;
        color: #0369a1;
        border: 1px solid #7dd3fc;
    }

    .cat-btn-tools:hover { background: #e0f2fe; }

    .cat-btn-fertilizers {
        background: #fefce8;
        color: #854d0e;
        border: 1px solid #fde047;
    }

    .cat-btn-fertilizers:hover { background: #fef9c3; }

    .cat-btn-medicinalkits {
        background: #fdf4ff;
        color: #7e22ce;
        border: 1px solid #d8b4fe;
    }

    .cat-btn-medicinalkits:hover { background: #f3e8ff; }

    /* LOADING & EMPTY */
    .loading-state, .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #6b7280;
    }

    .empty-icon { font-size: 72px; margin-bottom: 16px; }

    .empty-state h3 {
        font-size: 22px;
        font-weight: 700;
        color: #374151;
        margin-bottom: 8px;
    }

    .empty-state p { margin-bottom: 24px; }

    .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #dcfce7;
        border-top-color: #2e7d32;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 16px auto;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    /* MODAL */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(8px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        padding: 20px;
    }

    .modal-card {
        background: white;
        border-radius: 28px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.2);
        animation: slideUp 0.3s ease;
        max-height: 90vh;
        overflow-y: auto;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 28px 32px 0 32px;
    }

    .modal-header h2 {
        font-size: 24px;
        font-weight: 800;
        color: #1b5e20;
        margin-bottom: 6px;
    }

    .modal-header p { color: #6b7280; margin: 0; font-size: 14px; }

    .close-btn {
        background: #f3f4f6;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
        flex-shrink: 0;
    }

    .close-btn:hover { background: #e5e7eb; }

    .modal-body { padding: 24px 32px; }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .full-width { grid-column: 1 / -1; }

    .form-group label {
        font-size: 13px;
        font-weight: 700;
        color: #374151;
    }

    .form-input {
        border: 1.5px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 15px;
        outline: none;
        transition: 0.2s;
        color: #111827;
        width: 100%;
        box-sizing: border-box;
    }

    .form-input:focus {
        border-color: #2e7d32;
        box-shadow: 0 0 0 3px rgba(46,125,50,0.1);
    }

    .form-input-file {
        border: 1.5px dashed #e5e7eb;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 14px;
        outline: none;
        transition: 0.2s;
        color: #6b7280;
        width: 100%;
        box-sizing: border-box;
        background: #f9fafb;
        cursor: pointer;
    }

    .form-input-file:hover { border-color: #2e7d32; background: #f0fdf4; }

    .modal-footer {
        display: flex;
        gap: 14px;
        padding: 0 32px 28px 32px;
    }

    .cancel-btn {
        flex: 1;
        background: #f9fafb;
        border: 1.5px solid #e5e7eb;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        color: #374151;
        transition: 0.2s;
    }

    .cancel-btn:hover { background: #f3f4f6; }

    .save-btn {
        flex: 2;
        background: linear-gradient(135deg, #43a047, #2e7d32);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .save-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(67,160,71,0.3);
    }

    @@media (max-width: 768px) {
        .stats-row { grid-template-columns: repeat(2, 1fr); }
        .form-grid { grid-template-columns: 1fr; }
        .full-width { grid-column: 1; }
        .businesses-grid { grid-template-columns: 1fr; }
    }
</style>

@code {
    private List<BusinessModel>? businesses;
    private bool isAddProductModalOpen = false;
    private bool isEditMode = false;
    private string? selectedBusinessId;
    private PlantModel newProduct = new();
    private string selectedCategory { get; set; } = string.Empty;
    private string selectedSubCategory { get; set; } = string.Empty;
    private List<string> subCategories = new();

    private Dictionary<string, List<string>> categoryMap = new()
    {
        { "Plants", new List<string> { "Indoor Plants", "Outdoor Plants", "Decoration" } },
        { "Tools", new List<string> { "Gardening Tools", "Planting Tools" } },
        { "Fertilizers", new List<string> { "Organic Fertilizers", "Chemical Fertilizers" } },
        { "Medicinal Kits", new List<string> { "Herbal Kits", "Essential Kits" } }
    };

    protected override async Task OnInitializedAsync()
    {
        businesses = await BusinessService.GetAllBusinessesAsync();

        foreach (var biz in businesses)
        {
            biz.Products = await PlantService.GetProductsByBusinessIdAsync(biz.Id!);
        }
    }

    private void OpenAddProductModal(string businessId, PlantModel? product = null, string category = "")
    {
        selectedBusinessId = businessId;
        isEditMode = product != null;
        newProduct = product != null
            ? new PlantModel
            {
                Id = product.Id,
                PlantName = product.PlantName,
                Description = product.Description,
                Category = product.Category,
                SubCategory = product.SubCategory,
                Price = product.Price,
                Quantity = product.Quantity,
                ImageUrl = product.ImageUrl,
                BusinessId = product.BusinessId
            }
            : new PlantModel();

        selectedCategory = product?.Category ?? category;
        selectedSubCategory = product?.SubCategory ?? string.Empty;
        subCategories = categoryMap.ContainsKey(selectedCategory)
            ? categoryMap[selectedCategory]
            : new List<string>();

        isAddProductModalOpen = true;
    }

    private void CloseAddProductModal()
    {
        isAddProductModalOpen = false;
        isEditMode = false;
        newProduct = new PlantModel();
    }

    private async Task SaveProduct()
    {
        try
        {
            if (string.IsNullOrEmpty(selectedBusinessId)) return;

            newProduct.BusinessId = selectedBusinessId;
            newProduct.Category = selectedCategory;
            newProduct.SubCategory = selectedSubCategory;

            if (isEditMode)
                await PlantService.UpdateProductAsync(newProduct);
            else
                await PlantService.AddProductAsync(newProduct);

            isAddProductModalOpen = false;
            isEditMode = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            var webRoot = WebHostEnvironment.WebRootPath;
            if (string.IsNullOrEmpty(webRoot)) return;

            var uploadsFolder = Path.Combine(webRoot, "uploads");
            if (!Directory.Exists(uploadsFolder))
                Directory.CreateDirectory(uploadsFolder);

            var fileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
            var filePath = Path.Combine(uploadsFolder, fileName);

            using FileStream fs = new(filePath, FileMode.Create);
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(fs);

            newProduct.ImageUrl = $"/uploads/{fileName}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.ToString());
        }
    }
}