@page "/fertilizers"
@inject IPlantService PlantService
@rendermode InteractiveServer
@using Entities

<h3 class="text-success fw-bold mb-4">🌿 Fertilizers</h3>

@if (fertilizers == null)
{
    <p><em>Loading...</em></p>
}
else if (!fertilizers.Any())
{
    <p class="text-danger">No fertilizers found.</p>
}
else
{
    <!-- Search input -->
    <input class="form-control mb-3" placeholder="Search by fertilizer name..."
           @bind="searchTerm" @bind:event="oninput" />

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Fertilizer Name</th>
                <th>Category</th>
                <th>Sub Category</th>
                <th>Image</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fertilizer in fertilizers
                    .Where(f => string.IsNullOrEmpty(searchTerm)
                    || f.PlantName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
            {
                <tr>
                    <td>@fertilizer.PlantName</td>
                    <td>@fertilizer.Category</td>
                    <td>@fertilizer.SubCategory</td>
                    <td>
                        @if (!string.IsNullOrEmpty(fertilizer.ImageUrl))
                        {
                            <img src="@fertilizer.ImageUrl" alt="@fertilizer.PlantName" style="height:50px; width:auto;" />
                        }
                        else
                        {
                            <span class="text-muted">No Image</span>
                        }
                    </td>
                    <td>@fertilizer.Price</td>
                    <td>@fertilizer.Quantity</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => OpenEditModal(fertilizer)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteFertilizer(fertilizer.ProID)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (isEditModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Fertilizer</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingFertilizer" OnValidSubmit="SaveFertilizer">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Fertilizer Name</label>
                            <InputText class="form-control" @bind-Value="editingFertilizer.PlantName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Sub Category</label>
                            <InputText class="form-control" @bind-Value="editingFertilizer.SubCategory" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Price</label>
                            <InputNumber class="form-control" @bind-Value="editingFertilizer.Price" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Quantity</label>
                            <InputNumber class="form-control" @bind-Value="editingFertilizer.Quantity" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Image URL</label>
                            <InputText class="form-control" @bind-Value="editingFertilizer.ImageUrl" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Save</button>
                            <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PlantModel> fertilizers = new();
    private PlantModel editingFertilizer = new();
    private bool isEditModalOpen = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        fertilizers = await PlantService.GetProductsByCategoryAsync("Fertilizers");
    }

    private async Task DeleteFertilizer(string? id)
    {
        if (string.IsNullOrWhiteSpace(id)) return;
        await PlantService.DeleteProductAsync(id);

        fertilizers = await PlantService.GetProductsByCategoryAsync("Fertilizers");
        StateHasChanged();
    }

    private void OpenEditModal(PlantModel fertilizer)
    {
        editingFertilizer = new PlantModel
        {
            ProID = fertilizer.ProID,
            PlantName = fertilizer.PlantName,
            SubCategory = fertilizer.SubCategory,
            Price = fertilizer.Price,
            Quantity = fertilizer.Quantity,
            ImageUrl = fertilizer.ImageUrl,
            Category = fertilizer.Category,
            BusinessId = fertilizer.BusinessId
        };
        isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        isEditModalOpen = false;
        editingFertilizer = new PlantModel();
    }

    private async Task SaveFertilizer()
    {
        if (string.IsNullOrWhiteSpace(editingFertilizer.ProID)) return;

        await PlantService.UpdateProductAsync(editingFertilizer);

        fertilizers = await PlantService.GetProductsByCategoryAsync("Fertilizers");
        isEditModalOpen = false;
        StateHasChanged();
    }
}
