@page "/plants"
@inject IPlantService PlantService
@inject IWebHostEnvironment Environment
@rendermode InteractiveServer

@using Entities
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Hosting

<h3 class="text-success fw-bold mb-4">🌱 Plants</h3>

@if (plants == null)
{
    <p><em>Loading...</em></p>
}
else if (!plants.Any())
{
    <p class="text-danger">No plants found.</p>
}
else
{
    <!-- Search -->
    <input class="form-control mb-3"
           placeholder="Search by plant name..."
           @bind="searchTerm"
           @bind:event="oninput" />

    <!-- Table -->
    <div style="max-height:400px; overflow-y:auto; border:1px solid #ccc; border-radius:6px;">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-light sticky-top">
                <tr>
                    <th>Plant Name</th>
                    <th>Category</th>
                    <th>Sub Category</th>
                    <th>Image</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var plant in plants
                            .Where(p => string.IsNullOrEmpty(searchTerm)
                            || p.PlantName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
                {
                    <tr>
                        <td>@plant.PlantName</td>
                        <td>@plant.Category</td>
                        <td>@plant.SubCategory</td>

                        <td>
                            @if (!string.IsNullOrEmpty(plant.ImageUrl))
                            {
                                <img src="@plant.ImageUrl"
                                     alt="@plant.PlantName"
                                     style="height:60px; width:auto; border-radius:6px;" />
                            }
                            else
                            {
                                <span class="text-muted">No Image</span>
                            }
                        </td>

                        <td>@plant.Price</td>
                        <td>@plant.Quantity</td>

                        <td>
                            <button class="btn btn-sm btn-warning me-1"
                                    @onclick="() => OpenEditModal(plant)">
                                Edit
                            </button>

                            <button class="btn btn-sm btn-danger"
                                    @onclick="() => DeletePlant(plant.ProID)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Edit Modal -->
@if (isEditModalOpen)
{
    <div class="modal fade show d-block"
         tabindex="-1"
         style="background: rgba(0,0,0,0.5);">

        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Edit Plant</h5>

                    <button type="button"
                            class="btn-close"
                            @onclick="CloseEditModal">
                    </button>
                </div>

                <div class="modal-body">

                    <EditForm Model="editingPlant"
                              OnValidSubmit="SavePlant">

                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <!-- Plant Name -->
                        <div class="mb-3">
                            <label class="form-label">Plant Name</label>

                            <InputText class="form-control"
                                       @bind-Value="editingPlant.PlantName" />
                        </div>

                        <!-- Sub Category -->
                        <div class="mb-3">
                            <label class="form-label">Sub Category</label>

                            <InputText class="form-control"
                                       @bind-Value="editingPlant.SubCategory" />
                        </div>

                        <!-- Price -->
                        <div class="mb-3">
                            <label class="form-label">Price</label>

                            <InputNumber class="form-control"
                                         @bind-Value="editingPlant.Price" />
                        </div>

                        <!-- Quantity -->
                        <div class="mb-3">
                            <label class="form-label">Quantity</label>

                            <InputNumber class="form-control"
                                         @bind-Value="editingPlant.Quantity" />
                        </div>

                        <!-- File Upload -->
                        <div class="mb-3">
                            <label class="form-label">Upload Image</label>

                            <InputFile OnChange="HandleFileUpload"
                                       class="form-control" />

                            @if (!string.IsNullOrEmpty(editingPlant.ImageUrl))
                            {
                                <div class="mt-2">
                                    <img src="@editingPlant.ImageUrl"
                                         style="height:120px; border-radius:8px;" />
                                </div>
                            }
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-success">
                                Save
                            </button>

                            <button type="button"
                                    class="btn btn-secondary"
                                    @onclick="CloseEditModal">
                                Cancel
                            </button>
                        </div>

                    </EditForm>

                </div>
            </div>
        </div>
    </div>
}

@code {

    private List<PlantModel> plants = new();

    private PlantModel editingPlant = new();

    private bool isEditModalOpen = false;

    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        plants = await PlantService.GetProductsByCategoryAsync("Plants");
    }

    // DELETE
    private async Task DeletePlant(string? id)
    {
        if (string.IsNullOrWhiteSpace(id))
            return;

        await PlantService.DeleteProductAsync(id);

        plants = await PlantService.GetProductsByCategoryAsync("Plants");

        StateHasChanged();
    }

    // OPEN EDIT MODAL
    private void OpenEditModal(PlantModel plant)
    {
        editingPlant = new PlantModel
        {
            ProID = plant.ProID,
            PlantName = plant.PlantName,
            Category = plant.Category,
            SubCategory = plant.SubCategory,
            Price = plant.Price,
            Quantity = plant.Quantity,
            ImageUrl = plant.ImageUrl,
            BusinessId = plant.BusinessId
        };

        isEditModalOpen = true;
    }

    // CLOSE MODAL
    private void CloseEditModal()
    {
        isEditModalOpen = false;

        editingPlant = new PlantModel();
    }

    // SAVE PRODUCT
    private async Task SavePlant()
    {
        if (string.IsNullOrWhiteSpace(editingPlant.ProID))
            return;

        await PlantService.UpdateProductAsync(editingPlant);

        plants = await PlantService.GetProductsByCategoryAsync("Plants");

        isEditModalOpen = false;

        StateHasChanged();
    }

    // IMAGE UPLOAD
    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;

            if (file == null)
                return;

            // Create uploads folder
            var uploadsFolder = Path.Combine(Environment.WebRootPath, "uploads");

            if (!Directory.Exists(uploadsFolder))
            {
                Directory.CreateDirectory(uploadsFolder);
            }

            // Generate unique file name
            var fileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";

            // Full file path
            var filePath = Path.Combine(uploadsFolder, fileName);

            // Save file
            using FileStream fs = new(filePath, FileMode.Create);

            await file.OpenReadStream(10 * 1024 * 1024)
                      .CopyToAsync(fs);

            // Save relative path in DB
            editingPlant.ImageUrl = $"/uploads/{fileName}";
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
}