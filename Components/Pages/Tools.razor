@page "/tools"
@inject IPlantService PlantService
@rendermode InteractiveServer
@using Entities

<h3 class="text-success fw-bold mb-4">🛠️ Tools</h3>

@if (tools == null)
{
    <p><em>Loading...</em></p>
}
else if (!tools.Any())
{
    <p class="text-danger">No tools found.</p>
}
else
{
    <!-- Search input -->
    <input class="form-control mb-3" placeholder="Search by tool name..."
           @bind="searchTerm" @bind:event="oninput" />

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Tool Name</th>
                <th>Category</th>
                <th>Sub Category</th>
                <th>Image</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tool in tools
                    .Where(t => string.IsNullOrEmpty(searchTerm)
                    || t.PlantName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
            {
                <tr>
                    <td>@tool.PlantName</td>
                    <td>@tool.Category</td>
                    <td>@tool.SubCategory</td>
                    <td>
                        @if (!string.IsNullOrEmpty(tool.ImageUrl))
                        {
                            <img src="@tool.ImageUrl" alt="@tool.PlantName" style="height:50px; width:auto;" />
                        }
                        else
                        {
                            <span class="text-muted">No Image</span>
                        }
                    </td>
                    <td>@tool.Price</td>
                    <td>@tool.Quantity</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => OpenEditModal(tool)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteTool(tool.ProID)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (isEditModalOpen)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Tool</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingTool" OnValidSubmit="SaveTool">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Tool Name</label>
                            <InputText class="form-control" @bind-Value="editingTool.PlantName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Sub Category</label>
                            <InputText class="form-control" @bind-Value="editingTool.SubCategory" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Price</label>
                            <InputNumber class="form-control" @bind-Value="editingTool.Price" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Quantity</label>
                            <InputNumber class="form-control" @bind-Value="editingTool.Quantity" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Image URL</label>
                            <InputText class="form-control" @bind-Value="editingTool.ImageUrl" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Save</button>
                            <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PlantModel> tools = new();
    private PlantModel editingTool = new();
    private bool isEditModalOpen = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        // Fetch only Tools category
        tools = await PlantService.GetProductsByCategoryAsync("Tools");
    }

    private async Task DeleteTool(string? id)
    {
        if (string.IsNullOrWhiteSpace(id)) return;
        await PlantService.DeleteProductAsync(id);

        // Refresh list
        tools = await PlantService.GetProductsByCategoryAsync("Tools");
        StateHasChanged();
    }

    private void OpenEditModal(PlantModel tool)
    {
        editingTool = new PlantModel
        {
            ProID = tool.ProID,
            PlantName = tool.PlantName,
            SubCategory = tool.SubCategory,
            Price = tool.Price,
            Quantity = tool.Quantity,
            ImageUrl = tool.ImageUrl,
            Category = tool.Category,
            BusinessId = tool.BusinessId
        };

        isEditModalOpen = true;
    }

    private void CloseEditModal()
    {
        isEditModalOpen = false;
        editingTool = new PlantModel();
    }

    private async Task SaveTool()
    {
        if (string.IsNullOrWhiteSpace(editingTool.ProID)) return;

        await PlantService.UpdateProductAsync(editingTool);

        tools = await PlantService.GetProductsByCategoryAsync("Tools");
        isEditModalOpen = false;
        StateHasChanged();
    }
}
