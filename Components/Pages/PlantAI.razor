@page "/plant-ai"
@attribute [Authorize]
@layout UserMainLayout
@rendermode InteractiveServer

@inject GroqService GroqService
@inject IJSRuntime JSRuntime

<PageTitle>Plant AI Assistant</PageTitle>

<div class="ai-page">

    <div class="ai-header">

        <div>
            <h1>🌿 Plant AI Assistant</h1>
            <p>Ask anything about plants and gardening.</p>
        </div>

    </div>

    <div class="ai-chat-container">

        <div class="ai-chat-box" id="chatBox">

            @if (!Messages.Any())
            {
                <div class="empty-chat">

                    <div class="empty-icon">🌱</div>

                    <h3>Start chatting with Plant AI</h3>

                </div>
            }

            @foreach (var msg in Messages)
            {
                <div class="chat-wrapper @(msg.IsUser ? "user" : "ai")">

                    <div class="chat-bubble">

                        @((MarkupString)FormatMessage(msg.Text))

                    </div>

                </div>
            }

            @if (IsLoading)
            {
                <div class="chat-wrapper ai">

                    <div class="chat-bubble typing-bubble">

                        Thinking...

                    </div>

                </div>
            }

        </div>

        <div class="ai-input-section">

            <input class="ai-input"
                   placeholder="Ask your plant question..."
                   @bind="UserQuestion"
                   @bind:event="oninput"
                   @onkeypress="HandleKeyPress" />

            <button class="ai-send-btn"
                    @onclick="AskAI">

                Ask AI

            </button>

        </div>

    </div>

</div>

<style>

    .ai-page {
        padding: 30px;
        background: #f4f7f3;
        min-height: 100vh;
    }

    .ai-header {
        margin-bottom: 24px;
    }

        .ai-header h1 {
            font-size: 42px;
            font-weight: 800;
            color: #1b5e20;
        }

        .ai-header p {
            color: #6b7280;
        }

    /* CHAT CONTAINER */

    .ai-chat-container {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        height: 80vh;
        display: flex;
        flex-direction: column;
    }

    .ai-chat-box {
        flex: 1;
        overflow-y: auto;
        padding: 30px;
        background: #f9fafb;
    }

    /* EMPTY */

    .empty-chat {
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .empty-icon {
        font-size: 70px;
        margin-bottom: 20px;
    }

    /* CHAT */

    .chat-wrapper {
        display: flex;
        margin-bottom: 20px;
    }

        .chat-wrapper.user {
            justify-content: flex-end;
        }

        .chat-wrapper.ai {
            justify-content: flex-start;
        }

    .chat-bubble {
        max-width: 75%;
        padding: 18px 22px;
        border-radius: 22px;
        line-height: 1.8;
        font-size: 15px;
        word-break: break-word;
    }

    /* USER */

    .chat-wrapper.user .chat-bubble {
        background: linear-gradient(135deg,#43a047,#2e7d32);
        color: white;
        border-bottom-right-radius: 8px;
    }

    /* AI */

    .chat-wrapper.ai .chat-bubble {
        background: white;
        border: 1px solid #e5e7eb;
        color: #111827;
        border-bottom-left-radius: 8px;
    }

    /* INPUT */

    .ai-input-section {
        display: flex;
        gap: 16px;
        padding: 24px;
        border-top: 1px solid #e5e7eb;
        background: white;
    }

    .ai-input {
        flex: 1;
        border: 1px solid #d1d5db;
        border-radius: 18px;
        padding: 18px;
        font-size: 16px;
        outline: none;
    }

        .ai-input:focus {
            border-color: #43a047;
        }

    .ai-send-btn {
        border: none;
        background: linear-gradient(135deg,#43a047,#2e7d32);
        color: white;
        padding: 18px 30px;
        border-radius: 18px;
        font-weight: 700;
    }

        .ai-send-btn:hover {
            transform: translateY(-2px);
        }

    /* RESPONSIVE */

    @@media(max-width:768px) {

        .ai-page {
            padding: 16px;
        }

        .chat-bubble {
            max-width: 92%;
        }

        .ai-input-section {
            flex-direction: column;
        }

        .ai-send-btn {
            width: 100%;
        }
    }

</style>

@code {

    private string UserQuestion = "";

    private bool IsLoading = false;

    private List<ChatMessage> Messages = new();

    private async Task AskAI()
    {
        if (string.IsNullOrWhiteSpace(UserQuestion))
            return;

        Messages.Add(new ChatMessage
        {
            Text = UserQuestion,
            IsUser = true
        });

        var question = UserQuestion;

        UserQuestion = "";

        IsLoading = true;

        StateHasChanged();

        await ScrollToBottom();

        try
        {
            var response = await GroqService.AskPlantAssistant(question);

            Messages.Add(new ChatMessage
            {
                Text = response,
                IsUser = false
            });
        }
        catch
        {
            Messages.Add(new ChatMessage
            {
                Text = "Error contacting AI assistant.",
                IsUser = false
            });
        }

        IsLoading = false;

        StateHasChanged();

        await ScrollToBottom();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AskAI();
        }
    }

    private string FormatMessage(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "";

        return text
            .Replace("\n", "<br>")
            .Replace("**", "<b>")
            .Replace("##", "<br><br><strong>")
            .Replace("* ", "• ");
    }

    private async Task ScrollToBottom()
    {
        await JSRuntime.InvokeVoidAsync(
            "eval",
            "window.scrollTo(0, document.body.scrollHeight)"
        );
    }

    public class ChatMessage
    {
        public string Text { get; set; } = "";

        public bool IsUser { get; set; }
    }
}